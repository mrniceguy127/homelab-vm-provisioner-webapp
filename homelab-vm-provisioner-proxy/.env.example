# Environment configuration for homelab-vm-provisioner-proxy
# Copy this file to .env and customize as needed
# Parent workspace .env variables are loaded first, then these override them

# ==============================================================================
# Network Configuration
# ==============================================================================

# LOCAL_HOST: Default host/IP for service binding (inherited from parent)
# By default, scripts dynamically set this based on mode (localhost for native, 172.17.0.1 for Docker)
#LOCAL_HOST=localhost

# ==============================================================================
# Proxy Server Configuration
# ==============================================================================

# Proxy server port
PROXY_PORT=3000

# ==============================================================================
# API Backend Configuration
# ==============================================================================

# API backend host
# API_HOST defaults to LOCAL_HOST if not set
# For Docker on Linux: Use Docker bridge gateway
# API_HOST=172.17.0.1
# For Docker Desktop (macOS/Windows): Use host.docker.internal
# API_HOST=host.docker.internal
#API_HOST=localhost

# API port
API_PORT=3001
