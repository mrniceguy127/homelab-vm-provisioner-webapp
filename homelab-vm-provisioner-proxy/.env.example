# Environment configuration for homelab-vm-provisioner-proxy
# Copy this file to .env and customize as needed
# Parent workspace .env variables are loaded first, then these override them

# Proxy server port
PROXY_PORT=3000

# API backend host (combined with API_PORT to construct full URL)
# Linux (Docker): Use Docker bridge gateway
PROXY_API_HOST=http://172.17.0.1
# macOS/Windows Docker Desktop: Use host.docker.internal
#PROXY_API_HOST=http://host.docker.internal

# API port
API_PORT=3001
