# Environment configuration for homelab-vm-provisioner-proxy
# Copy this file to .env and customize as needed
# Parent workspace .env variables are loaded first, then these override them

# Proxy server port
PROXY_PORT=3000

# API backend URL
# Option 1: Set API_URL directly
# API_URL=http://localhost:3001

# Option 2: Set API_HOST and API_PORT separately (API_URL will be constructed)
# Linux (Docker): Use Docker bridge gateway
API_HOST=http://172.17.0.1
# macOS/Windows Docker Desktop: Use host.docker.internal
# API_HOST=http://host.docker.internal

# API port (used if API_URL not set directly)
API_PORT=3001
