# Environment configuration for homelab-vm-provisioner
# Copy this file to .env and customize as needed

# Port configuration
PROXY_PORT=3000
API_PORT=3001

# API URL for Docker proxy (used by start --docker and start-proxy-docker)
# Linux (default): 172.17.0.1 is Docker bridge gateway
# macOS/Windows Docker Desktop: use host.docker.internal
API_HOST=http://172.17.0.1

# Python provisioner virtual environment path
# Defaults to homelab-vm-provisioner-api/homelab-vm-provisioner-cli/.venv if not set
# PROVISIONER_VENV_DIR=/custom/path/to/.venv

# Additional environment variables (used by API at runtime)
# HLVMP_NETWORK_POOL_CIDR=10.80.0.0/16
# HLVMP_NETWORK_GROUP_PREFIX_LENGTH=28
