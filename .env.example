# ==============================================================================
# Homelab VM Provisioner - Monorepo Environment Configuration
# ==============================================================================
# Copy this file to .env and customize as needed
#
# This .env file is loaded by all components in the monorepo. Component-specific
# .env files can override these values. The hierarchy is:
#   1. Workspace .env (this file) - loaded first
#   2. Component .env - overrides workspace values
#
# To use: cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Build Mode Configuration
# ------------------------------------------------------------------------------
# Control which services are enabled during setup/build/start
# Set to "false" to disable a component

# Enable client (React frontend)
ENABLE_CLIENT=true

# Enable API (Express + Python provisioner)
ENABLE_API=true

# Enable database service (Node.js microservice for job queue)
ENABLE_DB_SERVICE=true

# Enable database (PostgreSQL)
ENABLE_DB=true

# Common build mode presets:
# - Full stack: all true (default)
# - Client only: ENABLE_CLIENT=true, others false
# - API only: ENABLE_API=true, ENABLE_DB_SERVICE=true, ENABLE_DB=true, ENABLE_CLIENT=false
# - DB standalone: ENABLE_DB=true, ENABLE_DB_SERVICE=true, others false
# ==============================================================================

# ------------------------------------------------------------------------------
# Port Configuration
# ------------------------------------------------------------------------------
# Ports for all services in the stack

# Reverse proxy port (client UI accessible at http://localhost:PROXY_PORT)
PROXY_PORT=3000

# API server port
API_PORT=3001

# Database microservice port (internal API for job queue)
DB_SERVICE_PORT=3002

# PostgreSQL database port (when running in Docker mode)
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL and database microservice settings

# Database microservice URL (used by API for async job operations)
DB_SERVICE_URL=http://localhost:3002

# Database microservice authentication (shared secret between API and DB service)
# IMPORTANT: Change this to a strong password in production
DB_SERVICE_PASSWORD=changeme_db_secret

# PostgreSQL connection URL (used by database microservice)
# Native mode: postgresql://hlvmp:hlvmppass@localhost:5432/hlvmp
# Docker mode: postgresql://hlvmp:hlvmppass@localhost:5432/hlvmp (host port mapped to container)
#  - Do no change HOST from default if running db micro service in docker mode.
#  - You may still change the password and database name, but keep the host and port default.
DATABASE_URL=postgresql://hlvmp:hlvmppass@localhost:5432/hlvmp

# PostgreSQL container configuration (used in --docker mode)
POSTGRES_USER=hlvmp
POSTGRES_PASSWORD=hlvmppass
POSTGRES_DB=hlvmp

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------

# Host identifier for job queue operations
# Used by API to identify which host is processing jobs in distributed setup
API_HOST_ID=local

# ------------------------------------------------------------------------------
# Proxy Configuration
# ------------------------------------------------------------------------------
# Reverse proxy routing to API backend

# API backend host for proxy (combined with API_PORT to construct full URL)
# For Docker mode (--docker):
#   - Linux: Use Docker bridge gateway (172.17.0.1)
#   - macOS/Windows Docker Desktop: Use host.docker.internal
# For native mode (default): Use localhost
PROXY_API_HOST=http://172.17.0.1

# API_PORT already defined above in Port Configuration section

# ------------------------------------------------------------------------------
# Provisioner Configuration (Python CLI)
# ------------------------------------------------------------------------------

# Python provisioner virtual environment path
# Defaults to homelab-vm-provisioner-api/homelab-vm-provisioner-cli/.venv if not set
#PROVISIONER_VENV_DIR=/custom/path/to/.venv

# Network configuration for VM provisioning
# CIDR block for VM network allocation
#HLVMP_NETWORK_POOL_CIDR=10.80.0.0/16

# Subnet prefix length for VM network groups
#HLVMP_NETWORK_GROUP_PREFIX_LENGTH=28

# ------------------------------------------------------------------------------
# Usage Examples
# ------------------------------------------------------------------------------
#
# Native mode (default):
#   ./setup && ./build && ./start
#   - Runs all services locally (PostgreSQL, Node.js, npm)
#   - Access at http://localhost:3000
#
# Docker mode:
#   ./setup --docker && ./build --docker && ./start --docker
#   - Runs database and proxy in Docker containers
#   - API runs locally to access host libvirt
#   - Access at http://localhost:3000
#
# Client-only mode (for frontend development with remote API):
#   ./setup --client-only && ./build --client-only && ./start --client-only
#   - Only builds and runs client + proxy
#   - Configure PROXY_API_HOST to point to remote API server
#
# Component-specific configuration:
#   Copy component .env.example files to .env in each subdirectory to override
#   workspace defaults for that specific component.
#
# ==============================================================================
