# ==============================================================================
# Homelab VM Provisioner - Monorepo Environment Configuration
# ==============================================================================
# Copy this file to .env and customize as needed
#
# This .env file is loaded by all components in the monorepo. Component-specific
# .env files can override these values. The hierarchy is:
#   1. Workspace .env (this file) - loaded first
#   2. Component .env - overrides workspace values
#
# To use: cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Network Configuration
# ------------------------------------------------------------------------------
# LOCAL_HOST: Default host/IP for service binding when specific service hosts
# are not provided. Services will bind to this address by default.
# - localhost: Bind to loopback only (local development, no external access)
# - 0.0.0.0: Bind to all interfaces (allows external connections)
# - 172.17.0.1: Docker bridge IP (for containerized environments on Linux)
# By default, scripts dynamically set this based on mode (localhost for native, 172.17.0.1 for Docker)
#LOCAL_HOST=localhost

# ------------------------------------------------------------------------------
# Build Mode Configuration
# ------------------------------------------------------------------------------
# Control which services are enabled during setup/build/start
# Set to "false" to disable a component

# Enable client (React frontend)
ENABLE_CLIENT=true

# Enable API (Express + Python provisioner)
ENABLE_API=true

# Enable db-interface (Node.js HTTP microservice in front of PostgreSQL)
ENABLE_DB_SERVICE=true

# Enable database (PostgreSQL engine + migrations)
ENABLE_DB=true

# Enable worker daemon (job processor)
ENABLE_WORKER=true

# Enable queue service (RabbitMQ)
ENABLE_QUEUE=true

# Common build mode presets:
# - Full stack: all true (default)
# - Client only: ENABLE_CLIENT=true, others false
# - API only: ENABLE_API=true, ENABLE_DB_SERVICE=true, ENABLE_DB=true, ENABLE_CLIENT=false
# - DB standalone: ENABLE_DB=true, ENABLE_DB_SERVICE=true, others false
# ==============================================================================

# ------------------------------------------------------------------------------
# Queue Configuration (RabbitMQ)
# ------------------------------------------------------------------------------
# RabbitMQ-based job queue settings
# Used by: API (publisher), Worker (consumer), Queue setup scripts

# RabbitMQ connection settings
# QUEUE_HOST: RabbitMQ server address (defaults to LOCAL_HOST if not set)
#QUEUE_HOST=localhost
QUEUE_PORT=3334
QUEUE_MGMT_PORT=13334
QUEUE_VHOST=provisioner
QUEUE_EXCHANGE=provisioner.jobs
QUEUE_ROUTING_KEY_PREFIX=host

# RabbitMQ admin credentials (used by queue setup/build scripts)
QUEUE_ADMIN_USER=admin
QUEUE_ADMIN_PASSWORD=change-me

# RabbitMQ API publisher credentials (used by API)
QUEUE_API_USER=provisioner_api
QUEUE_API_PASSWORD=change-me

# RabbitMQ worker consumer credentials (used by worker)
# Note: User name should match HOST_ID pattern for isolation
QUEUE_USER=worker_local
QUEUE_PASSWORD=change-me

# Worker queue configuration (derived from HOST_ID)
QUEUE_NAME=provisioner.worker.local
QUEUE_ROUTING_KEY=host.local

# Current host identity (used for queue routing and worker identification)
HOST_ID=local

# ==============================================================================

# ------------------------------------------------------------------------------
# Service Host Configuration
# ------------------------------------------------------------------------------
# Each service can override its host. If not set, defaults to LOCAL_HOST

# API server host (for worker and proxy to connect to)
# API_HOST defaults to LOCAL_HOST if not set
# API_HOST=localhost

# db-interface microservice host (for API and worker to connect to)
# DB_SERVICE_HOST defaults to LOCAL_HOST if not set
DB_SERVICE_HOST=localhost

# PostgreSQL host (for the db-interface microservice to connect to)
# POSTGRES_HOST defaults to LOCAL_HOST if not set
# POSTGRES_HOST=localhost

# ------------------------------------------------------------------------------
# Port Configuration
# ------------------------------------------------------------------------------
# Ports for all services in the stack

# Reverse proxy port (client UI accessible at http://localhost:PROXY_PORT)
PROXY_PORT=3000

# API server port
API_PORT=3001

# db-interface (database microservice) port
DB_SERVICE_PORT=3002

# PostgreSQL port
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Authentication & Secrets
# ------------------------------------------------------------------------------

# db-interface microservice password (used by API and worker)
DB_SERVICE_PASSWORD=changeme_db_secret

# PostgreSQL credentials
POSTGRES_USER=hlvmp
POSTGRES_PASSWORD=hlvmppass
POSTGRES_DB=hlvmp

# ------------------------------------------------------------------------------
# Resource Limits
# ------------------------------------------------------------------------------
# Maximum resource allocation per VM

# Maximum RAM per VM (in MB, default 8192 = 8GB)
HLVMP_VM_MAX_RAM_MB=8192

# Maximum vCPUs per VM (default 4)
HLVMP_VM_MAX_VCPUS=4

# Maximum disk size per VM (in GB, default 20)
HLVMP_VM_MAX_DISK_GB=20

# ==============================================================================

# ------------------------------------------------------------------------------
# Port Configuration
# ------------------------------------------------------------------------------
# Ports for all services in the stack

# Reverse proxy port (client UI accessible at http://localhost:PROXY_PORT)
PROXY_PORT=3000

# API server port
API_PORT=3001

# Database microservice port (internal API for job queue)
DB_SERVICE_PORT=3002

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL and database microservice settings

# Database microservice connection (used by worker and API for async job operations)
# URL is constructed from DB_SERVICE_HOST and DB_SERVICE_PORT
# Root start --docker rewrites defaults to 172.17.0.1 for containers

# Database microservice authentication (shared secret between API and DB service)
# IMPORTANT: Change this to a strong password in production
DB_SERVICE_PASSWORD=changeme_db_secret

# PostgreSQL connection settings (used by database microservice)
# Native mode: keep POSTGRES_HOST=localhost
# Root --docker mode: the database container is exposed on localhost:${POSTGRES_PORT}
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hlvmp
POSTGRES_PASSWORD=hlvmppass
POSTGRES_DB=hlvmp

# Legacy fallback for older setups that still rely on a single URL
#DATABASE_URL=postgresql://hlvmp:hlvmppass@localhost:5432/hlvmp

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------

# Host identifier for job queue operations
# Used by API to identify which host is processing jobs in distributed setup
HOST_ID=local

# ------------------------------------------------------------------------------
# Worker Configuration
# ------------------------------------------------------------------------------
# Long-running daemon that claims and executes queued jobs

# Path to homelab-vm-provisioner CLI
# Can be relative to monorepo root or absolute path
# Relative: homelab-vm-provisioner-cli
# Absolute: /opt/homelab/homelab-vm-provisioner-cli
PROVISIONER_CLI_PATH=homelab-vm-provisioner-cli

# Optional worker identifier (auto-generated if not set based on hostname+PID)
# WORKER_ID=my-worker-1

# Maximum concurrent jobs (default: 1)
# Increase cautiously - concurrent provisioning can be resource-intensive
PROVISIONER_CONCURRENCY=1

# Worker poll interval in seconds (default: 5.0)
WORKER_POLL_INTERVAL=5.0

# ------------------------------------------------------------------------------
# Provisioner Configuration (Python CLI)
# ------------------------------------------------------------------------------

# Python provisioner virtual environment path
# Defaults to homelab-vm-provisioner-cli/.venv if not set
#PROVISIONER_VENV_DIR=/custom/path/to/.venv

# Provisioner data directory
# Relative paths here are resolved from the monorepo root, then rewritten relative
# to the provisioner CLI checkout when passed to CLI-based components.
# Examples:
#   homelab-vm-provisioner-cli/data
#   .provisioner-data
#   /srv/hlvmp-data
#PROVISIONER_DATA_DIR=homelab-vm-provisioner-cli/data

# Provisioner data directory
# Relative paths resolve from the CLI directory, even when set here
# Defaults to homelab-vm-provisioner-cli/data
#PROVISIONER_DATA_DIR=data

# Network configuration for VM provisioning
# CIDR block for VM network allocation
#HLVMP_NETWORK_POOL_CIDR=10.80.0.0/16

# Subnet prefix length for VM network groups
#HLVMP_NETWORK_GROUP_PREFIX_LENGTH=28

# ------------------------------------------------------------------------------
# Usage Examples
# ------------------------------------------------------------------------------
#
# Native mode (default):
#   ./setup && ./build && ./start
#   - Runs all services locally (PostgreSQL, Node.js, npm)
#   - Access at http://localhost:3000
#
# Docker mode:
#   ./setup --docker && ./build --docker && ./start --docker
#   - Runs database, API, and proxy in Docker containers
#   - Worker remains local on the host
#   - Access at http://localhost:3000
#
# Client-only mode (for frontend development with remote API):
#   ./setup --client-only && ./build --client-only && ./start --client-only
#   - Only builds and runs client + proxy
#   - Configure API_HOST to point to remote API server
#
# Component-specific configuration:
#   Copy component .env.example files to .env in each subdirectory to override
#   workspace defaults for that specific component.
#
# ==============================================================================
