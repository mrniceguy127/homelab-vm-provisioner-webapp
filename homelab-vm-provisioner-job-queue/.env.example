# Environment configuration for homelab-vm-provisioner-job-queue
# Copy this file to .env and customize as needed

# ==============================================================================
# RabbitMQ Configuration
# ==============================================================================

# RabbitMQ connection settings
QUEUE_HOST=localhost
QUEUE_PORT=3334
QUEUE_VHOST=provisioner

# RabbitMQ topology
QUEUE_EXCHANGE=provisioner.jobs
QUEUE_ROUTING_KEY_PREFIX=host

# ==============================================================================
# RabbitMQ Credentials
# ==============================================================================

# Admin credentials (used by setup/build scripts to bootstrap RabbitMQ)
# These credentials create vhosts, users, exchanges, queues, and permissions
QUEUE_ADMIN_USER=admin
QUEUE_ADMIN_PASSWORD=change-me

# API publisher credentials (used by API to publish job messages)
# Separate from admin credentials for security
QUEUE_API_USER=provisioner_api
QUEUE_API_PASSWORD=change-me

# Worker consumer credentials (used by worker to consume jobs)
# One user per target host for isolation
# The worker user name should match the HOST_ID pattern
WORKER_QUEUE_USER=worker_local
WORKER_QUEUE_PASSWORD=change-me

# ==============================================================================
# Host Identity Configuration
# ==============================================================================

# Current host identity (used for routing)
# This determines the queue name and routing key for this host's workers
HOST_ID=local

# Derived values (built by scripts, not configured directly):
# - Queue name: provisioner.worker.${HOST_ID}
# - Routing key: host.${HOST_ID}

# ==============================================================================
# Package Installation Behavior
# ==============================================================================

# Skip system package installation (useful for containerized environments)
# When true, scripts will skip installing RabbitMQ and system packages
SKIP_SYSTEM_PACKAGES=false
