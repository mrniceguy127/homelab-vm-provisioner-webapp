#!/usr/bin/env bash
# Stop script for homelab-vm-provisioner-job-queue
#
# Usage: ./stop

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Source component .env
if [[ -f "$SCRIPT_DIR/.env" ]]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Defaults
QUEUE_MODE="${QUEUE_MODE:-docker}"

log() {
    printf '==> %s\n' "$*"
}

run_sudo() {
    if [[ "${EUID}" -eq 0 ]]; then
        "$@"
    else
        sudo "$@"
    fi
}

docker_container_running() {
    [[ "$(docker inspect -f '{{.State.Running}}' "$1" 2>/dev/null || true)" == "true" ]]
}

log "Stopping RabbitMQ (mode: $QUEUE_MODE)"

if [[ "$QUEUE_MODE" == "docker" ]]; then
    CONTAINER_NAME="hlvmp-rabbitmq"
    
    if docker_container_running "$CONTAINER_NAME"; then
        log "Stopping RabbitMQ container"
        docker stop "$CONTAINER_NAME"
        log "RabbitMQ container stopped"
    else
        log "RabbitMQ container is not running"
    fi
    
elif [[ "$QUEUE_MODE" == "non-docker" ]]; then
    if ! command -v rabbitmqctl >/dev/null 2>&1; then
        printf 'Error: RabbitMQ is not installed\n' >&2
        exit 1
    fi
    
    log "Stopping RabbitMQ system service"
    
    if command -v systemctl >/dev/null 2>&1; then
        run_sudo systemctl stop rabbitmq-server
        log "RabbitMQ service stopped"
    else
        printf 'Error: systemd not found\n' >&2
        printf 'Stop RabbitMQ manually: sudo service rabbitmq-server stop\n' >&2
        exit 1
    fi
    
else
    printf 'Error: Invalid QUEUE_MODE: %s\n' "$QUEUE_MODE" >&2
    exit 1
fi
