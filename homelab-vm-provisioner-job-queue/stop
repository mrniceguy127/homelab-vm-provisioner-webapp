#!/usr/bin/env bash
# Stop script for homelab-vm-provisioner-job-queue
#
# Usage: ./stop [--docker]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Source component .env
if [[ -f "$SCRIPT_DIR/.env" ]]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Defaults
DOCKER_MODE=false

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --docker)
            DOCKER_MODE=true
            ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Stop RabbitMQ service."
            echo ""
            echo "Options:"
            echo "  --docker    Stop RabbitMQ in Docker mode"
            echo "  --help      Show this help message"
            echo ""
            echo "Default: Stop native RabbitMQ service"
            exit 0
            ;;
    esac
done

log() {
    printf '==> %s\n' "$*"
}

run_sudo() {
    if [[ "${EUID}" -eq 0 ]]; then
        "$@"
    else
        sudo "$@"
    fi
}

docker_container_running() {
    [[ "$(docker inspect -f '{{.State.Running}}' "$1" 2>/dev/null || true)" == "true" ]]
}

docker_container_exists() {
    docker inspect "$1" >/dev/null 2>&1
}

# Auto-detect Docker mode if not explicitly specified
if [[ "$DOCKER_MODE" == "false" ]]; then
    CONTAINER_NAME="hlvmp-rabbitmq"
    if docker_container_exists "$CONTAINER_NAME" 2>/dev/null; then
        log "Auto-detected Docker mode (container exists)"
        DOCKER_MODE=true
    fi
fi

log "Stopping RabbitMQ (Docker mode: $DOCKER_MODE)"

if [[ "$DOCKER_MODE" == "true" ]]; then
    CONTAINER_NAME="hlvmp-rabbitmq"
    
    if docker_container_running "$CONTAINER_NAME"; then
        log "Stopping RabbitMQ container"
        docker stop "$CONTAINER_NAME"
        log "RabbitMQ container stopped"
    else
        log "RabbitMQ container is not running"
    fi
    
else
    # Native mode
    if ! command -v rabbitmqctl >/dev/null 2>&1; then
        printf 'Error: RabbitMQ is not installed\n' >&2
        exit 1
    fi
    
    log "Stopping RabbitMQ system service"
    
    if command -v systemctl >/dev/null 2>&1; then
        run_sudo systemctl stop rabbitmq-server
        log "RabbitMQ service stopped"
    else
        printf 'Error: systemd not found\n' >&2
        printf 'Stop RabbitMQ manually: sudo service rabbitmq-server stop\n' >&2
        exit 1
    fi
fi
