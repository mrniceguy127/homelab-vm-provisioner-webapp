#!/usr/bin/env bash
# Start script for homelab-vm-provisioner-job-queue
#
# Usage: ./start [--docker]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Source component .env
if [[ -f "$SCRIPT_DIR/.env" ]]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Defaults
DOCKER_MODE=false
QUEUE_HOST="${QUEUE_HOST:-localhost}"
QUEUE_PORT="${QUEUE_PORT:-3334}"
QUEUE_MGMT_PORT="${QUEUE_MGMT_PORT:-13334}"
QUEUE_ADMIN_USER="${QUEUE_ADMIN_USER:-admin}"
QUEUE_ADMIN_PASSWORD="${QUEUE_ADMIN_PASSWORD:-change-me}"

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --docker)
            DOCKER_MODE=true
            ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Start RabbitMQ service."
            echo ""
            echo "Options:"
            echo "  --docker    Start RabbitMQ in Docker"
            echo "  --help      Show this help message"
            echo ""
            echo "Default: Start native RabbitMQ service"
            exit 0
            ;;
    esac
done

log() {
    printf '==> %s\n' "$*"
}

run_sudo() {
    if [[ "${EUID}" -eq 0 ]]; then
        "$@"
    else
        sudo "$@"
    fi
}

docker_container_exists() {
    docker inspect "$1" >/dev/null 2>&1
}

docker_container_running() {
    [[ "$(docker inspect -f '{{.State.Running}}' "$1" 2>/dev/null || true)" == "true" ]]
}

wait_for_rabbitmq() {
    local max_attempts=30
    local attempt=0
    
    log "Waiting for RabbitMQ to be ready..."
    
    while [[ $attempt -lt $max_attempts ]]; do
        if curl -s -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
            "http://$QUEUE_HOST:$QUEUE_MGMT_PORT/api/overview" >/dev/null 2>&1; then
            log "RabbitMQ is ready"
            return 0
        fi
        
        attempt=$((attempt + 1))
        sleep 1
    done
    
    printf 'Error: RabbitMQ failed to become ready after %d seconds\n' "$max_attempts" >&2
    return 1
}

log "Starting RabbitMQ (Docker mode: $DOCKER_MODE)"

if [[ "$DOCKER_MODE" == "true" ]]; then
    CONTAINER_NAME="hlvmp-rabbitmq"
    
    if docker_container_running "$CONTAINER_NAME"; then
        log "RabbitMQ container already running"
    elif docker_container_exists "$CONTAINER_NAME"; then
        log "Starting existing RabbitMQ container"
        docker start "$CONTAINER_NAME"
    else
        log "Creating and starting RabbitMQ container"
        docker run -d \
            --name "$CONTAINER_NAME" \
            -p "$QUEUE_PORT:$QUEUE_PORT" \
            -p "$QUEUE_MGMT_PORT:$QUEUE_MGMT_PORT" \
            -e RABBITMQ_DEFAULT_USER="$QUEUE_ADMIN_USER" \
            -e RABBITMQ_DEFAULT_PASS="$QUEUE_ADMIN_PASSWORD" \
            -e RABBITMQ_NODE_PORT="$QUEUE_PORT" \
            -e RABBITMQ_MANAGEMENT_TCP_PORT="$QUEUE_MGMT_PORT" \
            -v hlvmp-rabbitmq-data:/var/lib/rabbitmq \
            rabbitmq:3-management
    fi
    
    wait_for_rabbitmq
    log "RabbitMQ container started successfully"
    log "Management UI: http://localhost:$QUEUE_MGMT_PORT"
    
else
    # Native mode
    if ! command -v rabbitmqctl >/dev/null 2>&1; then
        printf 'Error: RabbitMQ is not installed\n' >&2
        printf 'Run ./setup to install RabbitMQ\n' >&2
        exit 1
    fi
    
    log "Starting RabbitMQ system service"
    
    if command -v systemctl >/dev/null 2>&1; then
        run_sudo systemctl start rabbitmq-server
        run_sudo systemctl enable rabbitmq-server
    else
        printf 'Error: systemd not found\n' >&2
        printf 'Start RabbitMQ manually: sudo service rabbitmq-server start\n' >&2
        exit 1
    fi
    
    wait_for_rabbitmq
    log "RabbitMQ service started successfully"
fi

log "RabbitMQ is running on port $QUEUE_PORT"
