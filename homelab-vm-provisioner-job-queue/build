#!/usr/bin/env bash
# Build script for homelab-vm-provisioner-job-queue
#
# Provisions RabbitMQ topology: vhost, users, exchange, queues, bindings
# This script is idempotent and safe to run multiple times.
#
# Usage: ./build [--docker]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Source component .env
if [[ -f "$SCRIPT_DIR/.env" ]]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Parse arguments
DOCKER_MODE=false

for arg in "$@"; do
    case "$arg" in
        --docker)
            DOCKER_MODE=true
            ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Provision RabbitMQ topology (vhost, users, exchange, queues, bindings)."
            echo ""
            echo "Options:"
            echo "  --docker    Use Docker mode for RabbitMQ server lifecycle"
            echo "  --help      Show this help message"
            echo ""
            echo "This script starts RabbitMQ if not already running and provisions the topology."
            exit 0
            ;;
    esac
done

# Required environment variables
: "${QUEUE_HOST:?QUEUE_HOST is required}"
: "${QUEUE_PORT:?QUEUE_PORT is required}"
: "${QUEUE_MGMT_PORT:?QUEUE_MGMT_PORT is required}"
: "${QUEUE_VHOST:?QUEUE_VHOST is required}"
: "${QUEUE_EXCHANGE:?QUEUE_EXCHANGE is required}"
: "${QUEUE_ROUTING_KEY_PREFIX:?QUEUE_ROUTING_KEY_PREFIX is required}"
: "${QUEUE_ADMIN_USER:?QUEUE_ADMIN_USER is required}"
: "${QUEUE_ADMIN_PASSWORD:?QUEUE_ADMIN_PASSWORD is required}"
: "${QUEUE_API_USER:?QUEUE_API_USER is required}"
: "${QUEUE_API_PASSWORD:?QUEUE_API_PASSWORD is required}"
: "${WORKER_QUEUE_USER:?WORKER_QUEUE_USER is required}"
: "${WORKER_QUEUE_PASSWORD:?WORKER_QUEUE_PASSWORD is required}"
: "${HOST_ID:?HOST_ID is required}"

log() {
    printf '==> %s\n' "$*"
}

# Check if RabbitMQ is already running
is_rabbitmq_running() {
    curl -sf --max-time 2 -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
        "http://$QUEUE_HOST:$QUEUE_MGMT_PORT/api/overview" >/dev/null 2>&1
}

# Construct management API base URL
MGMT_API_BASE="http://$QUEUE_HOST:$QUEUE_MGMT_PORT/api"

# Derived values
QUEUE_NAME="provisioner.worker.$HOST_ID"
ROUTING_KEY="$QUEUE_ROUTING_KEY_PREFIX.$HOST_ID"

log "Provisioning RabbitMQ topology"
log "  Vhost: $QUEUE_VHOST"
log "  Exchange: $QUEUE_EXCHANGE"
log "  Queue: $QUEUE_NAME"
log "  Routing key: $ROUTING_KEY"
log ""

# Check if RabbitMQ is already running
RABBITMQ_WAS_RUNNING=false
if is_rabbitmq_running; then
    log "RabbitMQ is already running"
    RABBITMQ_WAS_RUNNING=true
else
    log "RabbitMQ is not running - starting it"
    if [[ "$DOCKER_MODE" == "true" ]]; then
        ./start --docker
    else
        ./start
    fi
    
    # Wait for RabbitMQ to be ready
    log "Waiting for RabbitMQ to be ready..."
    max_attempts=15
    attempt=0
    while [[ $attempt -lt $max_attempts ]]; do
        if is_rabbitmq_running; then
            log "RabbitMQ is ready"
            break
        fi
        attempt=$((attempt + 1))
        printf '.' >&2
        sleep 2
    done
    printf '\n' >&2
    
    if [[ $attempt -eq $max_attempts ]]; then
        printf 'Error: RabbitMQ failed to become ready after %d seconds\n' "$((max_attempts * 2))" >&2
        printf 'Check that RabbitMQ is running on %s:%s\n' "$QUEUE_HOST" "$QUEUE_MGMT_PORT" >&2
        exit 1
    fi
fi

# Create vhost
log "Creating vhost: $QUEUE_VHOST"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X PUT "$MGMT_API_BASE/vhosts/$QUEUE_VHOST" >/dev/null || true

# Create API publisher user
log "Creating API publisher user: $QUEUE_API_USER"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X PUT -H "Content-Type: application/json" \
    -d "{\"password\":\"$QUEUE_API_PASSWORD\",\"tags\":\"\"}" \
    "$MGMT_API_BASE/users/$QUEUE_API_USER" >/dev/null

# Grant API publisher permissions (write to exchange only)
log "Configuring API publisher permissions"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X PUT -H "Content-Type: application/json" \
    -d "{\"configure\":\"\",\"write\":\"$QUEUE_EXCHANGE\",\"read\":\"\"}" \
    "$MGMT_API_BASE/permissions/$QUEUE_VHOST/$QUEUE_API_USER" >/dev/null

# Create worker consumer user
log "Creating worker consumer user: $WORKER_QUEUE_USER"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X PUT -H "Content-Type: application/json" \
    -d "{\"password\":\"$WORKER_QUEUE_PASSWORD\",\"tags\":\"\"}" \
    "$MGMT_API_BASE/users/$WORKER_QUEUE_USER" >/dev/null

# Grant worker consumer permissions (read from queue only)
log "Configuring worker consumer permissions"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X PUT -H "Content-Type: application/json" \
    -d "{\"configure\":\"\",\"write\":\"\",\"read\":\"$QUEUE_NAME\"}" \
    "$MGMT_API_BASE/permissions/$QUEUE_VHOST/$WORKER_QUEUE_USER" >/dev/null

# Create exchange
log "Creating exchange: $QUEUE_EXCHANGE"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X PUT -H "Content-Type: application/json" \
    -d '{"type":"topic","durable":true}' \
    "$MGMT_API_BASE/exchanges/$QUEUE_VHOST/$QUEUE_EXCHANGE" >/dev/null

# Create worker queue
log "Creating queue: $QUEUE_NAME"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X PUT -H "Content-Type: application/json" \
    -d '{"durable":true,"arguments":{}}' \
    "$MGMT_API_BASE/queues/$QUEUE_VHOST/$QUEUE_NAME" >/dev/null

# Bind queue to exchange
log "Binding queue to exchange with routing key: $ROUTING_KEY"
curl -sf -u "$QUEUE_ADMIN_USER:$QUEUE_ADMIN_PASSWORD" \
    -X POST -H "Content-Type: application/json" \
    -d "{\"routing_key\":\"$ROUTING_KEY\",\"arguments\":{}}" \
    "$MGMT_API_BASE/bindings/$QUEUE_VHOST/e/$QUEUE_EXCHANGE/q/$QUEUE_NAME" >/dev/null

log ""
log "RabbitMQ topology provisioned successfully"
log "  Users created: $QUEUE_API_USER, $WORKER_QUEUE_USER"
log "  Exchange: $QUEUE_EXCHANGE (topic)"
log "  Queue: $QUEUE_NAME (durable)"
log "  Binding: $QUEUE_NAME <- $QUEUE_EXCHANGE via $ROUTING_KEY"

# Stop RabbitMQ if we started it
if [[ "$RABBITMQ_WAS_RUNNING" == "false" ]]; then
    log ""
    log "Stopping RabbitMQ (it was not running before build)"
    if [[ "$DOCKER_MODE" == "true" ]]; then
        ./stop --docker
    else
        ./stop
    fi
fi
