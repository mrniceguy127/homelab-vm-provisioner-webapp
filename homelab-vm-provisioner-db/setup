#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source component library
source "$SCRIPT_DIR/scripts/lib.sh"

# Source .env
source_env "$SCRIPT_DIR/.env"

# Parse arguments
SKIP_NPM=false
SKIP_SYSTEM_PACKAGES=false
DOCKER_MODE=false

for arg in "$@"; do
    case "$arg" in
        --skip-npm) SKIP_NPM=true ;;
        --skip-system-packages) SKIP_SYSTEM_PACKAGES=true ;;
        --docker) DOCKER_MODE=true ;;
        --help)
            cat <<HELP
Usage: $0 [OPTIONS]

Setup the database environment.

Options:
  --skip-npm               Skip npm install
  --skip-system-packages   Skip system package installation
  --docker                 Setup for Docker mode (skip PostgreSQL server install)
  --help                   Show this help message
HELP
            exit 0
            ;;
    esac
done

cd "$SCRIPT_DIR"

# Install system packages
if [[ "$SKIP_SYSTEM_PACKAGES" == false ]]; then
    ensure_sudo_once "Installing system packages requires sudo."
    
    if [[ "$DOCKER_MODE" == true ]]; then
        log "Docker mode: Installing PostgreSQL client only"
        install_system_packages_postgresql_client
    else
        log "Installing PostgreSQL server and client"
        install_system_packages_postgresql_server
    fi
    
    log "Installing Node.js"
    install_system_packages_nodejs
fi

log "Setting up database environment"

# Verify Node.js if system packages were skipped
if [[ "$SKIP_SYSTEM_PACKAGES" == "true" ]]; then
    require_cmd node
    require_cmd npm
    NODE_VERSION=$(node -v | cut -d. -f1 | tr -d 'v')
    [[ "$NODE_VERSION" -lt 18 ]] && error "Node.js 18+ required, found: $(node -v)" && exit 1
fi

# Install npm dependencies
if [[ "$SKIP_NPM" == false ]]; then
    log "Installing npm dependencies"
    npm install
fi

log "Database setup complete"
