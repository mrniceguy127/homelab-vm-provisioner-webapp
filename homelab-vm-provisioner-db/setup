#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source component library
source "$SCRIPT_DIR/scripts/lib.sh"

# Source .env
source_env "$SCRIPT_DIR/.env"

# Parse arguments
SKIP_SYSTEM_PACKAGES=false
DOCKER_MODE=false

for arg in "$@"; do
    case "$arg" in
        --skip-system-packages) SKIP_SYSTEM_PACKAGES=true ;;
        --docker) DOCKER_MODE=true ;;
        --skip-npm) ;;  # accepted for orchestrator compatibility; no npm here
        --help)
            cat <<HELP
Usage: $0 [OPTIONS]

Setup the PostgreSQL database environment.

Options:
  --skip-system-packages   Skip system package installation
  --docker                 Setup for Docker mode (pull postgres image)
  --help                   Show this help message
HELP
            exit 0
            ;;
    esac
done

cd "$SCRIPT_DIR"

if [[ "$DOCKER_MODE" == true ]]; then
    log "Docker mode: pulling PostgreSQL image"
    if ! command -v docker >/dev/null 2>&1; then
        error "Docker is not installed"
        printf 'Install Docker Desktop or Docker Engine before using Docker mode\n' >&2
        exit 1
    fi
    docker pull postgres:17
    log "PostgreSQL Docker image ready"
    log "Database setup complete"
    exit 0
fi

# Native mode
if [[ "$SKIP_SYSTEM_PACKAGES" == false ]]; then
    ensure_sudo_once "Installing system packages requires sudo."
    log "Installing PostgreSQL server and client"
    install_system_packages_postgresql_server
else
    log "Skipping PostgreSQL package installation"
    if ! command -v psql >/dev/null 2>&1; then
        error "PostgreSQL is not installed and package installation was skipped"
        printf 'Install PostgreSQL manually or run setup without --skip-system-packages\n' >&2
        exit 1
    fi
    log "PostgreSQL is already installed"
fi

log "Database setup complete"
