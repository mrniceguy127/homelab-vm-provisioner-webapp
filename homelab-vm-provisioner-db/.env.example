# Environment configuration for homelab-vm-provisioner-db
# Copy this file to .env and customize as needed
# Parent workspace .env variables are loaded first, then these override them

# ==============================================================================
# Network Configuration
# ==============================================================================

# LOCAL_HOST: Default host/IP for service binding (inherited from parent)
# By default, scripts dynamically set this based on mode (localhost for native, 172.17.0.1 for Docker)
#LOCAL_HOST=localhost

# ==============================================================================
# Database Microservice Configuration
# ==============================================================================

# Database microservice port (defaults to 3002)
DB_SERVICE_PORT=3002

# Database microservice authentication (shared secret)
# Change this to a strong password in production
# API and worker must provide this in Authorization header
DB_SERVICE_PASSWORD=changeme_db_secret

# ==============================================================================
# PostgreSQL Configuration
# ==============================================================================

# PostgreSQL connection settings (used by microservice)
# POSTGRES_HOST defaults to LOCAL_HOST if not set
#POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hlvmp
POSTGRES_PASSWORD=hlvmppass
POSTGRES_DB=hlvmp

# ==============================================================================
# Docker Mode Configuration
# ==============================================================================

# PostgreSQL container configuration (for --docker mode)
# Keep POSTGRES_HOST=localhost when the container includes PostgreSQL.
