# Environment configuration for homelab-vm-provisioner-db
# Copy this file to .env and customize as needed

# Database microservice port
DB_SERVICE_PORT=3002

# Database microservice authentication (shared secret)
# Change this to a strong password in production
# API must provide this in Authorization header
#DB_SERVICE_PASSWORD=changeme_db_secret

# PostgreSQL connection URL (used by microservice)
#DATABASE_URL=postgresql://hlvmp:hlvmppass@localhost:5432/hlvmp

# PostgreSQL container configuration (for --docker mode)
POSTGRES_PORT=5432
POSTGRES_USER=hlvmp
POSTGRES_PASSWORD=hlvmppass
POSTGRES_DB=hlvmp
