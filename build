#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
DB_DIR="$ROOT_DIR/homelab-vm-provisioner-db"
PROXY_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy"
QUEUE_DIR="$ROOT_DIR/homelab-vm-provisioner-job-queue"
PROXY_PUBLIC_DIR="$PROXY_DIR/public"

# Source .env file if it exists
if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    source "$ROOT_DIR/.env"
    set +a
fi

# Build mode defaults (can be overridden by .env)
ENABLE_CLIENT="${ENABLE_CLIENT:-true}"
ENABLE_API="${ENABLE_API:-true}"
ENABLE_DB_SERVICE="${ENABLE_DB_SERVICE:-true}"
ENABLE_DB="${ENABLE_DB:-true}"
ENABLE_QUEUE="${ENABLE_QUEUE:-true}"

# Parse arguments
USE_DOCKER=false
BUILD_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --client-only)
            # Legacy flag support - sets mode flags
            ENABLE_CLIENT=true
            ENABLE_API=false
            ENABLE_DB_SERVICE=false
            ENABLE_QUEUE=false
            ENABLE_DB=false
            ;;
        --docker)
            USE_DOCKER=true
            BUILD_ARGS+=("$arg")
            ;;
        *)
            BUILD_ARGS+=("$arg")
            ;;
    esac
done

log() {
    printf '==> %s\n' "$*"
}

# Display enabled services
log "Build mode configuration:"
log "  CLIENT:      $ENABLE_CLIENT"
log "  API:         $ENABLE_API"
log "  DB_SERVICE:  $ENABLE_DB_SERVICE"
log "  QUEUE:       $ENABLE_QUEUE"
log "  DB:          $ENABLE_DB"
log ""

# Build components
if [[ "$ENABLE_DB" == "true" || "$ENABLE_DB_SERVICE" == "true" ]]; then
    log "Building database"
    "$DB_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}
fi
QUEUE" == "true" ]]; then
    log "Building job queue"
    "$QUEUE_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}
fi

if [[ "$ENABLE_
if [[ "$ENABLE_API" == "true" ]]; then
    log "Building API"
    "$API_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}
fi

if [[ "$ENABLE_CLIENT" == "true" ]]; then
    log "Building client"
    "$CLIENT_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}

    # Wire up client artifacts to proxy
    log "Deploying client artifacts to proxy"
    rm -rf "$PROXY_PUBLIC_DIR"
    mkdir -p "$PROXY_PUBLIC_DIR"
    cp -R "$CLIENT_DIR/dist/." "$PROXY_PUBLIC_DIR/"
    log "Client files deployed to: $PROXY_PUBLIC_DIR"

    # Build proxy Docker image if in Docker mode
    if [[ "$USE_DOCKER" == "true" ]]; then
        log "Building proxy Docker image"
        "$PROXY_DIR/build" --docker
    fi
fi

log "Workspace build complete"
