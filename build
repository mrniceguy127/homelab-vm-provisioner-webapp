#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source shared library
source "$ROOT_DIR/scripts/lib.sh"

# Component directories
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
DB_DIR="$ROOT_DIR/homelab-vm-provisioner-db"
PROXY_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy"
QUEUE_DIR="$ROOT_DIR/homelab-vm-provisioner-job-queue"
PROXY_PUBLIC_DIR="$PROXY_DIR/public"

# Source .env file if it exists
source_env "$ROOT_DIR/.env"

# Build mode defaults (can be overridden by .env)
ENABLE_CLIENT="${ENABLE_CLIENT:-true}"
ENABLE_API="${ENABLE_API:-true}"
ENABLE_DB_SERVICE="${ENABLE_DB_SERVICE:-true}"
ENABLE_DB="${ENABLE_DB:-true}"
ENABLE_QUEUE="${ENABLE_QUEUE:-true}"

# Parse arguments
DOCKER_MODE=false
BUILD_ARGS=()

for arg in "$@"; do
    case "$arg" in
        --client-only)
            ENABLE_CLIENT=true
            ENABLE_API=false
            ENABLE_DB_SERVICE=false
            ENABLE_QUEUE=false
            ENABLE_DB=false
            ;;
        --docker)
            DOCKER_MODE=true
            BUILD_ARGS+=("$arg")
            ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Build all workspace components."
            echo ""
            echo "Options:"
            echo "  --client-only    Build only client and proxy"
            echo "  --docker         Build with Docker"
            echo "  --help           Show this help message"
            exit 0
            ;;
        *)
            BUILD_ARGS+=("$arg")
            ;;
    esac
done

# Display enabled services
log "Build configuration:"
log "  CLIENT:      $ENABLE_CLIENT"
log "  API:         $ENABLE_API"
log "  DB_SERVICE:  $ENABLE_DB_SERVICE"
log "  QUEUE:       $ENABLE_QUEUE"
log "  DB:          $ENABLE_DB"
echo ""

# Build components
[[ "$ENABLE_DB" == "true" || "$ENABLE_DB_SERVICE" == "true" ]] && log "Building database" && "$DB_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}
[[ "$ENABLE_QUEUE" == "true" ]] && log "Building job queue" && "$QUEUE_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}
[[ "$ENABLE_API" == "true" ]] && log "Building API" && "$API_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}

if [[ "$ENABLE_CLIENT" == "true" ]]; then
    log "Building client"
    "$CLIENT_DIR/build" ${BUILD_ARGS[@]+"${BUILD_ARGS[@]}"}

    log "Deploying client artifacts to proxy"
    rm -rf "$PROXY_PUBLIC_DIR"
    mkdir -p "$PROXY_PUBLIC_DIR"
    cp -R "$CLIENT_DIR/dist/." "$PROXY_PUBLIC_DIR/"
    
    [[ "$DOCKER_MODE" == "true" ]] && log "Building proxy Docker image" && "$PROXY_DIR/build" --docker
fi

log "Build complete"
