#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
API_PUBLIC_DIR="$API_DIR/public"

log() {
    printf '==> %s\n' "$*"
}

log "Running API build (tests, coverage, docs)"
npm --prefix "$API_DIR" run build

log "Running client build (tests, coverage, app build, docs)"
npm --prefix "$CLIENT_DIR" run build

log "Running client Playwright tests"
npm --prefix "$CLIENT_DIR" run test:e2e

log "Deploying client bundle to API public directory"
rm -rf "$API_PUBLIC_DIR"
mkdir -p "$API_PUBLIC_DIR"
cp -R "$CLIENT_DIR/dist/." "$API_PUBLIC_DIR/"

log "Workspace build complete"
