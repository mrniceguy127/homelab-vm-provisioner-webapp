#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
PROXY_PUBLIC_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy/public"

# Source .env file if it exists
if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    source "$ROOT_DIR/.env"
    set +a
fi

# Parse arguments
USE_DOCKER=false
CLIENT_ONLY=false
for arg in "$@"; do
    case "$arg" in
        --docker)
            USE_DOCKER=true
            ;;
        --client-only)
            CLIENT_ONLY=true
            ;;
    esac
done

log() {
    printf '==> %s\n' "$*"
}

if [[ "$CLIENT_ONLY" == "false" ]]; then
    log "Building API (docs)"
    npm --prefix "$API_DIR" run build
else
    log "Client-only mode: skipping API build"
fi

if [[ "$USE_DOCKER" == "true" ]]; then
    log "Building client with Docker"
    "$CLIENT_DIR/build"
    
    log "Building client docs (local)"
    npm --prefix "$CLIENT_DIR" run docs:build
else
    log "Building client (app + docs)"
    npm --prefix "$CLIENT_DIR" run build
    
    log "Deploying client bundle to proxy public directory"
    rm -rf "$PROXY_PUBLIC_DIR"
    mkdir -p "$PROXY_PUBLIC_DIR"
    cp -R "$CLIENT_DIR/dist/." "$PROXY_PUBLIC_DIR/"
fi

log "Workspace build complete"
