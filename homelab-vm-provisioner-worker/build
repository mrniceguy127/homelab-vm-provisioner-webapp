#!/usr/bin/env bash
# Build script for homelab-vm-provisioner-worker
#
# Worker cannot be dockerized as it must run on the host.
# This script runs linting and validates the build.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Activate virtual environment if it exists
VENV_DIR=".venv"
if [[ -d "$VENV_DIR" ]]; then
  source "$VENV_DIR/bin/activate"
fi

echo "==> Running linter (ruff)"
if command -v ruff &> /dev/null; then
  ruff check hlvmp_worker/ tests/
  echo "Linting passed"
else
  echo "Warning: ruff not installed, skipping linting"
  echo "Install with: pip install ruff"
fi

echo ""
echo "Build complete!"
