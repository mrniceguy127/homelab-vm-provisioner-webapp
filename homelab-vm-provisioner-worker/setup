#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source component library
source "$SCRIPT_DIR/scripts/lib.sh"

# Source .env
source_env "$SCRIPT_DIR/.env"

# Determine provisioner CLI path (supports monorepo and standalone)
PROVISIONER_CLI_PATH="${PROVISIONER_CLI_PATH:-homelab-vm-provisioner-cli}"
if [[ "$PROVISIONER_CLI_PATH" != /* ]]; then
    # Relative path - try parent directory first (monorepo), then current
    if [[ -d "$SCRIPT_DIR/../$PROVISIONER_CLI_PATH" ]]; then
        PROVISIONER_DIR="$SCRIPT_DIR/../$PROVISIONER_CLI_PATH"
    else
        PROVISIONER_DIR="$SCRIPT_DIR/$PROVISIONER_CLI_PATH"
    fi
else
    PROVISIONER_DIR="$PROVISIONER_CLI_PATH"
fi
PROVISIONER_VENV_DIR="${PROVISIONER_VENV_DIR:-$PROVISIONER_DIR/.venv}"

# Parse arguments
SKIP_SYSTEM_PACKAGES=false
INSTALL_DEV=false
PROVISIONER_ARGS=()

for arg in "$@"; do
    case "$arg" in
        --skip-system-packages) SKIP_SYSTEM_PACKAGES=true; PROVISIONER_ARGS+=("$arg") ;;
        --dev) INSTALL_DEV=true; PROVISIONER_ARGS+=("$arg") ;;
        --help)
            cat <<EOF
Usage: $0 [OPTIONS]

Setup the worker daemon environment.

Options:
  --skip-system-packages  Skip system package installation
  --dev                   Install development dependencies
  --help                  Show this help message

Environment variables:
  PROVISIONER_CLI_PATH    Path to provisioner CLI (default: ../homelab-vm-provisioner-cli)
  PROVISIONER_VENV_DIR    Provisioner virtualenv path (default: \$PROVISIONER_CLI_PATH/.venv)
EOF
            exit 0
            ;;
        *)
            error "Unknown option: $arg"
            exit 1
            ;;
    esac
done

cd "$SCRIPT_DIR"

# Install system packages
if [[ "$SKIP_SYSTEM_PACKAGES" == "false" ]]; then
    ensure_sudo_once "Installing system packages requires sudo."
    log "Installing Python"
    install_system_packages_python
fi

# Verify Python if system packages were skipped
if [[ "$SKIP_SYSTEM_PACKAGES" == "true" ]] && ! command -v python3 &>/dev/null; then
    error "python3 not found. Install Python 3.9+"
    exit 1
fi

# Check for provisioner CLI
[[ ! -d "$PROVISIONER_DIR" ]] && error "Provisioner CLI not found at: $PROVISIONER_DIR" && exit 1
[[ ! -x "$PROVISIONER_DIR/setup" ]] && error "Provisioner setup script not found at: $PROVISIONER_DIR/setup" && exit 1

# Setup provisioner CLI if needed
if [[ -d "$PROVISIONER_VENV_DIR" && ! -x "$PROVISIONER_VENV_DIR/bin/python" ]]; then
    log "Removing incomplete provisioner virtualenv"
    rm -rf "$PROVISIONER_VENV_DIR"
fi

mkdir -p "$(dirname "$PROVISIONER_VENV_DIR")"

log "Running provisioner CLI setup"
"$PROVISIONER_DIR/setup" ${PROVISIONER_ARGS[@]+"${PROVISIONER_ARGS[@]}"} --venv "$PROVISIONER_VENV_DIR"

# Create worker virtualenv
VENV_DIR=".venv"
[[ ! -d "$VENV_DIR" ]] && log "Creating worker virtualenv" && python3 -m venv "$VENV_DIR"

# Activate and install
source "$VENV_DIR/bin/activate"
log "Installing worker package"
pip install --upgrade pip
[[ "$INSTALL_DEV" == "true" ]] && pip install -e ".[dev]" || pip install -e .

log "Worker setup complete. Start with: ./start"
