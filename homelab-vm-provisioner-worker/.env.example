# Environment configuration for homelab-vm-provisioner-worker
# Copy this file to .env and customize as needed

# Host identifier for job claiming (required)
HOST_ID=local

# Database microservice URL (required)
DB_SERVICE_URL=http://localhost:3002

# Database microservice authentication (shared secret, required)
DB_SERVICE_PASSWORD=changeme_db_secret

# Path to homelab-vm-provisioner CLI (optional, defaults to PATH lookup)
# In monorepo: set to ../homelab-vm-provisioner-cli
# PROVISIONER_CLI_PATH=/path/to/homelab-vm-provisioner-cli

# Optional worker identifier (auto-generated if not set)
# WORKER_ID=my-worker-1

# Maximum concurrent jobs (default: 1)
# Increase cautiously - concurrent provisioning can be resource-intensive
PROVISIONER_CONCURRENCY=1

# Worker poll interval in seconds (default: 5.0)
WORKER_POLL_INTERVAL=5.0

# Unix socket path for wakeup mechanism (optional)
# If set, the worker will listen on this socket for wake/health messages
# Default: /run/hlvmp/worker.sock
# WORKER_SOCKET=/run/hlvmp/worker.sock
