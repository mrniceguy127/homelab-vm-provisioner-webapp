# Environment configuration for homelab-vm-provisioner-worker
# Copy this file to .env and customize as needed
# Parent workspace .env variables are loaded first, then these override them

# ==============================================================================
# Network Configuration
# ==============================================================================

# LOCAL_HOST: Default host/IP for service binding (inherited from parent)
# By default, scripts dynamically set this based on mode (localhost for native, 172.17.0.1 for Docker)
#LOCAL_HOST=localhost

# ==============================================================================
# Host Identity Configuration
# ==============================================================================

# Host identifier for job claiming (REQUIRED)
# Used for host-specific queue and routing
HOST_ID=local

# Worker identity (used for host-specific queue)
# WORKER_HOST_ID takes precedence over HOST_ID if both are set
# Defaults to HOST_ID if WORKER_HOST_ID is not set
# WORKER_HOST_ID=local

# Optional worker identifier (auto-generated if not set)
# WORKER_ID=my-worker-1

# ==============================================================================
# Database Microservice Configuration
# ==============================================================================

# Database microservice connection (required)
# DB_SERVICE_HOST defaults to LOCAL_HOST if not set
DB_SERVICE_HOST=localhost
DB_SERVICE_PORT=3002

# Database microservice URL is constructed from DB_SERVICE_HOST and DB_SERVICE_PORT

# Database microservice authentication (shared secret, required)
DB_SERVICE_PASSWORD=changeme_db_secret

# ==============================================================================
# RabbitMQ Consumer Configuration
# ==============================================================================

# Worker requires RabbitMQ for job consumption
# All QUEUE_* variables default to parent workspace values if not overridden

# RabbitMQ connection settings
# QUEUE_HOST defaults to LOCAL_HOST if not set
#QUEUE_HOST=localhost
QUEUE_PORT=3334
QUEUE_VHOST=provisioner
QUEUE_EXCHANGE=provisioner.jobs

# Worker queue configuration (derived from HOST_ID/WORKER_HOST_ID)
QUEUE_NAME=provisioner.worker.local
QUEUE_ROUTING_KEY=host.local

# RabbitMQ worker credentials
QUEUE_USER=worker_local
QUEUE_PASSWORD=change-me

# ==============================================================================
# API Connection Configuration
# ==============================================================================

# API connection for job status reporting (REQUIRED)
# API_HOST defaults to LOCAL_HOST if not set
# API_HOST=localhost
API_PORT=3001

# ==============================================================================
# Provisioner CLI Configuration
# ==============================================================================

# Path to provisioner CLI package (REQUIRED - no default)
# MUST be explicitly configured for microservice independence
# For monorepo: set to absolute path of homelab-vm-provisioner-cli
# Example: /path/to/homelab-vm-provisioner-cli
PROVISIONER_CLI_PATH=

# ==============================================================================
# Worker Behavior Configuration
# ==============================================================================

# Maximum concurrent jobs (default: 1)
# Increase cautiously - concurrent provisioning can be resource-intensive
PROVISIONER_CONCURRENCY=1

# Dry-run mode (default: false)
# When enabled, commands are logged but not executed
# Automatically enabled if libvirt/system dependencies are unavailable
# Set to true for development without VM infrastructure
WORKER_DRY_RUN=false
