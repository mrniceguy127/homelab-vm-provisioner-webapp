#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source shared library
source "$ROOT_DIR/scripts/lib.sh"

# Component directories
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
PROXY_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy"
DB_DIR="$ROOT_DIR/homelab-vm-provisioner-db"
DB_INTERFACE_DIR="$ROOT_DIR/homelab-vm-provisioner-db-interface"
WORKER_DIR="$ROOT_DIR/homelab-vm-provisioner-worker"
QUEUE_DIR="$ROOT_DIR/homelab-vm-provisioner-job-queue"

PROVISIONER_CLI_PATH="${PROVISIONER_CLI_PATH:-homelab-vm-provisioner-cli}"
if [[ "$PROVISIONER_CLI_PATH" != /* ]]; then
    PROVISIONER_DIR="$ROOT_DIR/$PROVISIONER_CLI_PATH"
else
    PROVISIONER_DIR="$PROVISIONER_CLI_PATH"
fi

# Source .env file if it exists
source_env "$ROOT_DIR/.env"

# Build mode defaults (can be overridden by .env)
ENABLE_CLIENT="${ENABLE_CLIENT:-true}"
ENABLE_API="${ENABLE_API:-true}"
ENABLE_DB_SERVICE="${ENABLE_DB_SERVICE:-true}"
ENABLE_DB="${ENABLE_DB:-true}"
ENABLE_WORKER="${ENABLE_WORKER:-true}"
ENABLE_QUEUE="${ENABLE_QUEUE:-true}"

# Parse arguments
INSTALL_DEV=false
SKIP_SYSTEM_PACKAGES=false
DOCKER_MODE=false
SETUP_ARGS=()

for arg in "$@"; do
    case "$arg" in
        --docker)
            DOCKER_MODE=true
            SETUP_ARGS+=("$arg")
            ;;
        --dev)
            INSTALL_DEV=true
            SETUP_ARGS+=("$arg")
            ;;
        --skip-system-packages)
            SKIP_SYSTEM_PACKAGES=true
            SETUP_ARGS+=("$arg")
            ;;
        --client-only)
            ENABLE_CLIENT=true
            ENABLE_API=false
            ENABLE_DB_SERVICE=false
            ENABLE_DB=false
            ENABLE_QUEUE=false
            ENABLE_WORKER=false
            ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Setup the entire monorepo workspace."
            echo ""
            echo "Options:"
            echo "  --docker                 Setup for Docker mode"
            echo "  --dev                    Install development dependencies"
            echo "  --skip-system-packages   Skip system package installation"
            echo "  --client-only            Setup only client and proxy"
            echo "  --help                   Show this help message"
            exit 0
            ;;
        *)
            SETUP_ARGS+=("$arg")
            ;;
    esac
done

# Display enabled services
log "Setup configuration:"
log "  WORKER:      $ENABLE_WORKER"
log "  CLIENT:      $ENABLE_CLIENT"
log "  API:         $ENABLE_API"
log "  DB_SERVICE:  $ENABLE_DB_SERVICE"
log "  QUEUE:       $ENABLE_QUEUE"
log "  DB:          $ENABLE_DB"
echo ""

# Check required paths based on enabled services
[[ "$ENABLE_CLIENT" == "true" ]] && require_path "$CLIENT_DIR" && require_path "$PROXY_DIR"
[[ "$ENABLE_API" == "true" ]] && require_path "$API_DIR" && require_path "$PROVISIONER_DIR"
[[ "$ENABLE_DB" == "true" ]] && require_path "$DB_DIR"
[[ "$ENABLE_DB_SERVICE" == "true" ]] && require_path "$DB_INTERFACE_DIR"
[[ "$ENABLE_WORKER" == "true" ]] && require_path "$WORKER_DIR"

# Check for git (required for submodule initialization)
require_cmd git

# Request sudo once upfront if system packages will be installed
if [[ "$SKIP_SYSTEM_PACKAGES" == "false" ]]; then
    ensure_sudo_once "System package installation requires sudo. Confirm once now."
fi

# Initialize git submodules if needed
SUBMODULES_TO_INIT=()
[[ "$ENABLE_API" == "true" ]] && SUBMODULES_TO_INIT+=("$API_DIR")
[[ "$ENABLE_CLIENT" == "true" ]] && SUBMODULES_TO_INIT+=("$CLIENT_DIR")

if [[ ${#SUBMODULES_TO_INIT[@]} -gt 0 ]]; then
    NEEDS_INIT=false
    for submodule in "${SUBMODULES_TO_INIT[@]}"; do
        if [[ ! -e "$submodule/.git" ]]; then
            NEEDS_INIT=true
            break
        fi
    done
    
    if [[ "$NEEDS_INIT" == "true" ]]; then
        log "Initializing git submodules"
        git -C "$ROOT_DIR" submodule update --init --recursive
    fi
fi

# Setup components
[[ "$ENABLE_DB" == "true" ]] && log "Setting up database (PostgreSQL)" && "$DB_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
[[ "$ENABLE_DB_SERVICE" == "true" ]] && log "Setting up db-interface" && "$DB_INTERFACE_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
[[ "$ENABLE_QUEUE" == "true" ]] && log "Setting up job queue" && "$QUEUE_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
[[ "$ENABLE_API" == "true" ]] && log "Setting up API" && "$API_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}

# Worker doesn't have --docker mode, filter it out
if [[ "$ENABLE_WORKER" == "true" ]]; then
    log "Setting up worker"
    WORKER_ARGS=()
    for arg in ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}; do
        [[ "$arg" != "--docker" ]] && WORKER_ARGS+=("$arg")
    done
    "$WORKER_DIR/setup" ${WORKER_ARGS[@]+"${WORKER_ARGS[@]}"}
fi

if [[ "$ENABLE_CLIENT" == "true" ]]; then
    log "Setting up client"
    [[ "$DOCKER_MODE" == "true" && "$INSTALL_DEV" == "false" ]] && "$CLIENT_DIR/setup" --skip-npm --skip-playwright ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"} || "$CLIENT_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
    
    log "Setting up proxy"
    [[ "$DOCKER_MODE" == "true" && "$INSTALL_DEV" == "false" ]] && "$PROXY_DIR/setup" --skip-npm ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"} || "$PROXY_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
fi

log "Setup complete"
