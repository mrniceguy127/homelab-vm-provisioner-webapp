#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
PROXY_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy"
DB_DIR="$ROOT_DIR/homelab-vm-provisioner-db"
WORKER_DIR="$ROOT_DIR/homelab-vm-provisioner-worker"
PROVISIONER_DIR="$API_DIR/homelab-vm-provisioner-cli"
PROVISIONER_VENV_DIR="${PROVISIONER_VENV_DIR:-$PROVISIONER_DIR/.venv}"
INSTALL_DEV=false

# Source .env file if it exists (sets build mode flags)
if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    source "$ROOT_DIR/.env"
    set +a
fi

# Build mode defaults (can be overridden by .env)
ENABLE_CLIENT="${ENABLE_CLIENT:-true}"
ENABLE_API="${ENABLE_API:-true}"
ENABLE_DB_SERVICE="${ENABLE_DB_SERVICE:-true}"
ENABLE_DB="${ENABLE_DB:-true}"
ENABLE_WORKER="${ENABLE_WORKER:-true}"

# Parse arguments
USE_DOCKER=false
SETUP_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --docker)
            USE_DOCKER=true
            ;;
        --dev)
            INSTALL_DEV=true
            SETUP_ARGS+=("$arg")
            ;;
        --skip-system-packages)
            SETUP_ARGS+=("$arg")
            ;;
        --client-only)
            # Legacy flag support - sets mode flags
            ENABLE_CLIENT=true
            ENABLE_API=false
            ENABLE_DB_SERVICE=false
            ENABLE_DB=false
            ENABLE_WORKER=false
            ;;
        *)
            SETUP_ARGS+=("$arg")
            ;;
    esac
done

log() {
    printf '==> %s\n' "$*"
}

require_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        printf 'Missing command: %s\n' "$1" >&2
        printf 'Please run component setup scripts to install dependencies\n' >&2
        exit 1
    fi
}

require_path() {
    if [[ ! -e "$1" ]]; then
        printf 'Missing required path: %s\n' "$1" >&2
        exit 1
    fi
}

# Display enabled services
log "Build mode configuration:"
log "  WORKER:      $ENABLE_WORKER"
log "  CLIENT:      $ENABLE_CLIENT"
log "  API:         $ENABLE_API"
log "  DB_SERVICE:  $ENABLE_DB_SERVICE"
log "  DB:          $ENABLE_DB"
log ""

# Check required paths based on enabled services
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    require_path "$CLIENT_DIR"
    require_path "$PROXY_DIR"
fi

if [[ "$ENABLE_API" == "true" ]]; then
    require_path "$API_DIR"
    require_path "$PROVISIONER_DIR"
    require_path "$PROVISIONER_DIR/setup"
fi

if [[ "$ENABLE_DB_SERVICE" == "true" || "$ENABLE_DB" == "true" ]]; then
    require_path "$DB_DIR"
fi

# Check for git (required for submodule initialization)
require_cmd git

# Initialize git submodules based on enabled services
SUBMODULES_TO_INIT=()
if [[ "$ENABLE_API" == "true" ]]; then
    SUBMODULES_TO_INIT+=("$API_DIR")
fi
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    SUBMODULES_TO_INIT+=("$CLIENT_DIR")
fi

if [[ ${#SUBMODULES_TO_INIT[@]} -gt 0 ]]; then
    # Check if any required submodules are missing
    NEEDS_INIT=false
    for submodule in "${SUBMODULES_TO_INIT[@]}"; do
        if [[ ! -e "$submodule/.git" ]]; then
            NEEDS_INIT=true
            break
        fi
    done
    
    if [[ "$NEEDS_INIT" == "true" ]]; then
        log "Initializing git submodules"
        git -C "$ROOT_DIR" submodule update --init --recursive
    else
        log "Git submodules already initialized; preserving local changes"
    fi
fi

# Setup components using their own setup scripts
if [[ "$ENABLE_DB" == "true" || "$ENABLE_DB_SERVICE" == "true" ]]; then
    log "Setting up database"
    "$DB_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
fi

if [[ "$ENABLE_API" == "true" ]]; then
    log "Setting up API and provisioner"
    "$API_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
fi

if [[ "$ENABLE_WORKER" == "true" ]]; then
    log "Setting up worker daemon"
    "$WORKER_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
fi

# Setup client
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    log "Setting up client"
    if [[ "$USE_DOCKER" == "true" && "$INSTALL_DEV" == "false" ]]; then
        "$CLIENT_DIR/setup" --skip-npm --skip-playwright ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
    else
        "$CLIENT_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
    fi
fi

# Setup proxy
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    log "Setting up proxy"
    if [[ "$USE_DOCKER" == "true" && "$INSTALL_DEV" == "false" ]]; then
        "$PROXY_DIR/setup" --skip-npm ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
    else
        "$PROXY_DIR/setup" ${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}
    fi
fi

log "Setup complete"
