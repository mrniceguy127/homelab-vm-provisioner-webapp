#!/usr/bin/env bash
set -uo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_ROOT="$ROOT_DIR"  # Save original root before it gets overridden
PYTHON_DIR="$ROOT_DIR/homelab-vm-provisioner-api/homelab-vm-provisioner-cli"
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'
CLEAR_LINE='\033[2K'

# Result tracking
declare -a RESULTS=()
OVERALL_SUCCESS=true

# Test selection flags
RUN_CLI=false
RUN_WORKER=false
RUN_API=false
RUN_CLIENT=false
USE_ENV_CONFIG=false

# Parse arguments
show_help() {
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Run tests for homelab-vm-provisioner monorepo components."
    echo ""
    echo "Options:"
    echo "  --all       Run all tests (default if no flags specified)"
    echo "  --cli       Run Python CLI tests only"
    echo "  --worker    Run Python Worker tests only"
    echo "  --api       Run Node.js API tests only"
    echo "  --client    Run React Client tests only"
    echo "  --env       Test only components enabled in .env (falls back to all if .env missing)"
    echo "  -h, --help  Show this help message"
    echo ""
    echo "Examples:"
    echo "  $0                    # Run all tests"
    echo "  $0 --all              # Run all tests"
    echo "  $0 --cli --worker     # Run CLI and Worker tests only"
    echo "  $0 --api              # Run API tests only"
    echo "  $0 --env              # Run tests based on .env configuration"
    exit 0
}

# Load test selection from .env file
load_env_config() {
    local env_file="$ROOT_DIR/.env"
    
    if [[ ! -f "$env_file" ]]; then
        echo -e "${YELLOW}Warning: .env file not found, testing all components${RESET}"
        RUN_CLI=true
        RUN_WORKER=true
        RUN_API=true
        RUN_CLIENT=true
        return
    fi
    
    # Reset all flags when using --env
    RUN_CLI=false
    RUN_WORKER=false
    RUN_API=false
    RUN_CLIENT=false
    
    # Source .env and read ENABLE_* variables
    # Use a subshell to avoid polluting current environment
    local enable_api=$(grep -E "^ENABLE_API=" "$env_file" | cut -d= -f2 | tr -d ' "'"'" | head -1)
    local enable_worker=$(grep -E "^ENABLE_WORKER=" "$env_file" | cut -d= -f2 | tr -d ' "'"'" | head -1)
    local enable_client=$(grep -E "^ENABLE_CLIENT=" "$env_file" | cut -d= -f2 | tr -d ' "'"'" | head -1)
    
    # Set CLI based on ENABLE_API (CLI is part of the API component)
    if [[ "$enable_api" == "true" ]]; then
        RUN_CLI=true
        RUN_API=true
    fi
    
    # Set Worker
    if [[ "$enable_worker" == "true" ]]; then
        RUN_WORKER=true
    fi
    
    # Set Client
    if [[ "$enable_client" == "true" ]]; then
        RUN_CLIENT=true
    fi
    
    # If nothing enabled, default to all
    if ! $RUN_CLI && ! $RUN_WORKER && ! $RUN_API && ! $RUN_CLIENT; then
        echo -e "${YELLOW}Warning: No components enabled in .env, testing all${RESET}"
        RUN_CLI=true
        RUN_WORKER=true
        RUN_API=true
        RUN_CLIENT=true
    fi
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --all)
            RUN_CLI=true
            RUN_WORKER=true
            RUN_API=true
            RUN_CLIENT=true
            shift
            ;;
        --cli)
            RUN_CLI=true
            shift
            ;;
        --worker)
            RUN_WORKER=true
            shift
            ;;
        --api)
            RUN_API=true
            shift
            ;;
        --client)
            RUN_CLIENT=true
            shift
            ;;
        --env)
            USE_ENV_CONFIG=true
            shift
            ;;
        -h|--help)
            show_help
            ;;
        *)
            echo "Error: Unknown option: $1"
            echo "Run '$0 --help' for usage information."
            exit 1
            ;;
    esac
done

# If --env flag specified, load configuration from .env
if $USE_ENV_CONFIG; then
    load_env_config
# If no flags specified, run all tests
elif ! $RUN_CLI && ! $RUN_WORKER && ! $RUN_API && ! $RUN_CLIENT; then
    RUN_CLI=true
    RUN_WORKER=true
    RUN_API=true
    RUN_CLIENT=true
fi

# Progress spinner
SPINNER_PID=""
spinner() {
    local message=$1
    local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    
    while true; do
        local char="${spinstr:i++%${#spinstr}:1}"
        printf "\r${CLEAR_LINE}${CYAN}${char}${RESET} ${message}..."
        sleep 0.1
    done
}

start_spinner() {
    spinner "$1" &
    SPINNER_PID=$!
}

stop_spinner() {
    if [[ -n "$SPINNER_PID" ]]; then
        kill "$SPINNER_PID" 2>/dev/null
        wait "$SPINNER_PID" 2>/dev/null
        printf "\r${CLEAR_LINE}"
        SPINNER_PID=""
    fi
}

print_header() {
    echo ""
    echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BOLD}  $1${RESET}"
    echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
}

print_result() {
    local project=$1
    local status=$2
    local lint=$3
    local tests=$4
    local coverage=$5
    
    if [[ "$status" == "PASS" ]]; then
        echo -e "${GREEN}✓${RESET} ${BOLD}$project${RESET}"
        echo -e "  Linting:  ${GREEN}$lint${RESET}"
        echo -e "  Tests:    ${GREEN}$tests${RESET}"
        echo -e "  Coverage: ${GREEN}$coverage${RESET}"
        RESULTS+=("${GREEN}✓${RESET} $project: Lint ${GREEN}$lint${RESET}, ${GREEN}$tests${RESET}, Coverage ${GREEN}$coverage${RESET}")
    elif [[ "$status" == "SKIP" ]]; then
        echo -e "${YELLOW}⊘${RESET} ${BOLD}$project${RESET}"
        echo -e "  ${YELLOW}$lint${RESET}"
        RESULTS+=("${YELLOW}⊘${RESET} $project: ${YELLOW}$lint${RESET}")
    else
        echo -e "${RED}✗${RESET} ${BOLD}$project${RESET}"
        echo -e "  Linting:  ${YELLOW}$lint${RESET}"
        echo -e "  Tests:    ${RED}$tests${RESET}"
        echo -e "  Coverage: ${YELLOW}$coverage${RESET}"
        RESULTS+=("${RED}✗${RESET} $project: Lint ${YELLOW}$lint${RESET}, ${RED}$tests${RESET}, Coverage ${YELLOW}$coverage${RESET}")
        OVERALL_SUCCESS=false
    fi
    echo ""
}

# ============================================
# Test Functions
# ============================================

test_python_cli() {
    print_header "Python CLI (homelab-vm-provisioner-cli)"

    cd "$PYTHON_DIR" || exit 1

    # Source Python environment
    export ROOT_DIR="$PYTHON_DIR"
    source "$PYTHON_DIR/scripts/_resolve_python.sh"
    resolve_python_env

    # Run linting
    PYTHON_LINT_OUTPUT=$(mktemp)
    start_spinner "Linting Python CLI"
    if "$PYTHON_BIN" -m ruff check "$PYTHON_DIR/homelab_vm_provisioner" "$PYTHON_DIR/tests" > "$PYTHON_LINT_OUTPUT" 2>&1; then
        stop_spinner
        PYTHON_LINT="passed"
    else
        stop_spinner
        PYTHON_LINT="issues found"
    fi

    # Run tests with coverage
    PYTHON_OUTPUT=$(mktemp)
    start_spinner "Running Python CLI tests"
    if "$PYTHON_BIN" -m coverage run --source=homelab_vm_provisioner -m unittest \
        tests.test_config tests.test_provision tests.test_adapters tests.test_services \
        tests.test_managed_nftables tests.test_reconciler tests.test_main tests.test_network \
        tests.test_system tests.test_cli tests.test_integration \
        > "$PYTHON_OUTPUT" 2>&1; then
        stop_spinner
        # Check if tests actually passed (no failures/errors)
        if grep -q "FAILED\|ERROR" "$PYTHON_OUTPUT"; then
            PYTHON_STATUS="FAIL"
        else
            PYTHON_STATUS="PASS"
        fi
    else
        stop_spinner
        PYTHON_STATUS="FAIL"
    fi

    # Extract test count
    PYTHON_TESTS=$(grep -E "Ran [0-9]+ tests" "$PYTHON_OUTPUT" | sed -E 's/Ran ([0-9]+) tests.*/\1 tests/')
    if [[ -z "$PYTHON_TESTS" ]]; then
        PYTHON_TESTS="unknown"
    fi

    # Check for failures/errors
    PYTHON_FAILURES=$(grep -E "FAILED \(failures=[0-9]+, errors=[0-9]+\)" "$PYTHON_OUTPUT" | sed -E 's/FAILED \((.*)\)/\1/')
    if [[ -n "$PYTHON_FAILURES" ]]; then
        PYTHON_TESTS="$PYTHON_TESTS ($PYTHON_FAILURES)"
    elif grep -q "^OK" "$PYTHON_OUTPUT"; then
        PYTHON_TESTS="$PYTHON_TESTS (all passed)"
    fi

    # Get coverage
    PYTHON_COV_OUTPUT=$(mktemp)
    "$PYTHON_BIN" -m coverage report 2>/dev/null | grep "^TOTAL" > "$PYTHON_COV_OUTPUT" || true
    PYTHON_COVERAGE=$(awk '{print $NF}' "$PYTHON_COV_OUTPUT")
    if [[ -z "$PYTHON_COVERAGE" ]]; then
        PYTHON_COVERAGE="N/A"
    fi

    print_result "Python CLI" "$PYTHON_STATUS" "$PYTHON_LINT" "$PYTHON_TESTS" "$PYTHON_COVERAGE"
    rm -f "$PYTHON_OUTPUT" "$PYTHON_COV_OUTPUT" "$PYTHON_LINT_OUTPUT"
}

test_python_worker() {
    print_header "Python Worker (homelab-vm-provisioner-worker)"

    WORKER_DIR="$WORKSPACE_ROOT/homelab-vm-provisioner-worker"
    cd "$WORKER_DIR" || exit 1

    # Check if worker tests can run
    if [[ ! -d "$WORKER_DIR/.venv" ]]; then
        echo -e "${YELLOW}Warning: Worker virtual environment not found. Skipping worker tests.${RESET}"
        WORKER_STATUS="SKIP"
        WORKER_LINT="Virtual environment not found. Run ./setup in worker directory."
        print_result "Python Worker" "$WORKER_STATUS" "$WORKER_LINT" "" ""
        return
    fi

    source "$WORKER_DIR/.venv/bin/activate"

    # Run linting
    WORKER_LINT_OUTPUT=$(mktemp)
    start_spinner "Linting Python Worker"
    if python -m ruff check "$WORKER_DIR/hlvmp_worker" "$WORKER_DIR/tests" > "$WORKER_LINT_OUTPUT" 2>&1; then
        stop_spinner
        WORKER_LINT="passed"
    else
        stop_spinner
        WORKER_LINT="issues found"
    fi

    # Run tests with coverage
    WORKER_OUTPUT=$(mktemp)
    start_spinner "Running Python Worker tests"
    if python -m coverage run --rcfile "$WORKER_DIR/pyproject.toml" -m unittest discover -s "$WORKER_DIR/tests" > "$WORKER_OUTPUT" 2>&1; then
        stop_spinner
        # Check if tests actually passed (look for unittest failure messages)
        if grep -qE "^(FAILED \(|ERROR:)" "$WORKER_OUTPUT"; then
            WORKER_STATUS="FAIL"
        else
            WORKER_STATUS="PASS"
        fi
    else
        stop_spinner
        WORKER_STATUS="FAIL"
    fi

    # Extract test count
    WORKER_TESTS=$(grep -E "Ran [0-9]+ tests" "$WORKER_OUTPUT" | sed -E 's/Ran ([0-9]+) tests.*/\1 tests/')
    if [[ -z "$WORKER_TESTS" ]]; then
        WORKER_TESTS="unknown"
    fi

    # Check for failures/errors
    WORKER_FAILURES=$(grep -E "FAILED \(failures=[0-9]+, errors=[0-9]+\)" "$WORKER_OUTPUT" | sed -E 's/FAILED \((.*)\)/\1/')
    if [[ -n "$WORKER_FAILURES" ]]; then
        WORKER_TESTS="$WORKER_TESTS ($WORKER_FAILURES)"
    elif grep -q "^OK" "$WORKER_OUTPUT"; then
        WORKER_TESTS="$WORKER_TESTS (all passed)"
    fi

    # Get coverage
    WORKER_COV_OUTPUT=$(mktemp)
    python -m coverage report --rcfile "$WORKER_DIR/pyproject.toml" 2>/dev/null | grep "^TOTAL" > "$WORKER_COV_OUTPUT" || true
    WORKER_COVERAGE=$(awk '{print $NF}' "$WORKER_COV_OUTPUT")
    if [[ -z "$WORKER_COVERAGE" ]]; then
        WORKER_COVERAGE="N/A"
    fi

    print_result "Python Worker" "$WORKER_STATUS" "$WORKER_LINT" "$WORKER_TESTS" "$WORKER_COVERAGE"
    rm -f "$WORKER_OUTPUT" "$WORKER_COV_OUTPUT" "$WORKER_LINT_OUTPUT"
    
    deactivate
}

test_nodejs_api() {
    print_header "Node.js API (homelab-vm-provisioner-api)"

    cd "$API_DIR" || exit 1

    # Run linting
    API_LINT_OUTPUT=$(mktemp)
    start_spinner "Linting Node.js API"
    if npm run lint > "$API_LINT_OUTPUT" 2>&1; then
        stop_spinner
        API_LINT="passed"
    else
        stop_spinner
        API_LINT="issues found"
    fi

    API_OUTPUT=$(mktemp)
    start_spinner "Running Node.js API tests"
    if npm run coverage > "$API_OUTPUT" 2>&1; then
        stop_spinner
        API_STATUS="PASS"
    else
        stop_spinner
        API_STATUS="FAIL"
    fi

    # Extract test results - look for vitest summary
    API_TEST_LINE=$(grep -E "Tests[[:space:]]+[0-9]+ passed" "$API_OUTPUT" | tail -1)
    if [[ -n "$API_TEST_LINE" ]]; then
        # Extract: "Tests  111 passed (111)"
        API_TESTS=$(echo "$API_TEST_LINE" | sed -E 's/.*Tests[[:space:]]+([0-9]+) passed.*/\1 tests passed/')
    else
        # Fallback to file count
        API_TEST_LINE=$(grep -E "Test Files.*passed" "$API_OUTPUT" | tail -1)
        if [[ -n "$API_TEST_LINE" ]]; then
            API_TESTS=$(echo "$API_TEST_LINE" | sed -E 's/.*Test Files[[:space:]]+([0-9]+) passed.*/\1 test files passed/')
        else
            API_TESTS="unknown"
        fi
    fi

    # Extract coverage - look for "All files" line
    API_COV_LINE=$(grep -E "All files" "$API_OUTPUT" | tail -1)
    if [[ -n "$API_COV_LINE" ]]; then
        # Extract percentage from line like: "All files        |   87.13 |    64.28 |   87.22 |   87.13 |"
        # First percentage after "All files" is the overall line coverage
        API_COVERAGE=$(echo "$API_COV_LINE" | sed -E 's/.*All files[[:space:]]*\|[[:space:]]*([0-9]+\.[0-9]+).*/\1/')"%"
    else
        API_COVERAGE="N/A"
    fi

    print_result "Node.js API" "$API_STATUS" "$API_LINT" "$API_TESTS" "$API_COVERAGE"
    rm -f "$API_OUTPUT" "$API_LINT_OUTPUT"
}

test_react_client() {
    print_header "React Client (homelab-vm-provisioner-client)"

    cd "$CLIENT_DIR" || exit 1

    # Run linting
    CLIENT_LINT_OUTPUT=$(mktemp)
    start_spinner "Linting React Client"
    if npm run lint > "$CLIENT_LINT_OUTPUT" 2>&1; then
        stop_spinner
        CLIENT_LINT="passed"
    else
        stop_spinner
        CLIENT_LINT="warnings"
    fi

    CLIENT_OUTPUT=$(mktemp)
    start_spinner "Running React Client tests"
    if npm run coverage > "$CLIENT_OUTPUT" 2>&1; then
        stop_spinner
        CLIENT_STATUS="PASS"
    else
        stop_spinner
        CLIENT_STATUS="FAIL"
    fi

    # Extract test results
    CLIENT_TEST_LINE=$(grep -E "Tests[[:space:]]+[0-9]+ passed" "$CLIENT_OUTPUT" | tail -1)
    if [[ -n "$CLIENT_TEST_LINE" ]]; then
        CLIENT_TESTS=$(echo "$CLIENT_TEST_LINE" | sed -E 's/.*Tests[[:space:]]+([0-9]+) passed.*/\1 tests passed/')
    else
        # Fallback to file count
        CLIENT_TEST_LINE=$(grep -E "Test Files.*passed" "$CLIENT_OUTPUT" | tail -1)
        if [[ -n "$CLIENT_TEST_LINE" ]]; then
            CLIENT_TESTS=$(echo "$CLIENT_TEST_LINE" | sed -E 's/.*Test Files[[:space:]]+([0-9]+) passed.*/\1 test files passed/')
        else
            CLIENT_TESTS="unknown"
        fi
    fi

    # Extract coverage
    CLIENT_COV_LINE=$(grep -E "All files" "$CLIENT_OUTPUT" | tail -1)
    if [[ -n "$CLIENT_COV_LINE" ]]; then
        CLIENT_COVERAGE=$(echo "$CLIENT_COV_LINE" | sed -E 's/.*All files[[:space:]]*\|[[:space:]]*([0-9]+\.[0-9]+).*/\1/')"%"
    else
        CLIENT_COVERAGE="N/A"
    fi

    print_result "React Client" "$CLIENT_STATUS" "$CLIENT_LINT" "$CLIENT_TESTS" "$CLIENT_COVERAGE"
    rm -f "$CLIENT_OUTPUT" "$CLIENT_LINT_OUTPUT"
}

# ============================================
# Run Selected Tests
# ============================================

if $RUN_CLI; then
    test_python_cli
fi

if $RUN_WORKER; then
    test_python_worker
fi

if $RUN_API; then
    test_nodejs_api
fi

if $RUN_CLIENT; then
    test_react_client
fi

# ============================================
# Summary
# ============================================
echo ""
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${BOLD}  SUMMARY${RESET}"
echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""

for result in "${RESULTS[@]}"; do
    echo -e "  $result"
done

echo ""
if $OVERALL_SUCCESS; then
    echo -e "${BOLD}${GREEN}✓ All tests passed!${RESET}"
    echo ""
    exit 0
else
    echo -e "${BOLD}${RED}✗ Some tests failed${RESET}"
    echo ""
    exit 1
fi
