#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source shared library
source "$ROOT_DIR/scripts/lib.sh"

# Component directories
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
DB_DIR="$ROOT_DIR/homelab-vm-provisioner-db"
DB_INTERFACE_DIR="$ROOT_DIR/homelab-vm-provisioner-db-interface"
PROXY_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy"
WORKER_DIR="$ROOT_DIR/homelab-vm-provisioner-worker"
QUEUE_DIR="$ROOT_DIR/homelab-vm-provisioner-job-queue"
PROXY_PUBLIC_INDEX="$PROXY_DIR/public/index.html"

PROVISIONER_CLI_PATH="${PROVISIONER_CLI_PATH:-homelab-vm-provisioner-cli}"
[[ "$PROVISIONER_CLI_PATH" != /* ]] && PROVISIONER_DIR="$ROOT_DIR/$PROVISIONER_CLI_PATH" || PROVISIONER_DIR="$PROVISIONER_CLI_PATH"

# Source .env file
source_env "$ROOT_DIR/.env"

# Build mode defaults
ENABLE_CLIENT="${ENABLE_CLIENT:-true}"
ENABLE_API="${ENABLE_API:-true}"
ENABLE_DB_SERVICE="${ENABLE_DB_SERVICE:-true}"
ENABLE_DB="${ENABLE_DB:-true}"
ENABLE_WORKER="${ENABLE_WORKER:-true}"
ENABLE_QUEUE="${ENABLE_QUEUE:-true}"

PROVISIONER_VENV_DIR="${PROVISIONER_VENV_DIR:-$PROVISIONER_DIR/.venv}"
PROVISIONER_PYTHON_BIN="$PROVISIONER_VENV_DIR/bin/python"

# Set LOCAL_HOST helper
set_local_host() {
    [[ -z "${LOCAL_HOST:-}" ]] && LOCAL_HOST=$([[ "${DOCKER_MODE:-false}" == "true" ]] && echo "172.17.0.1" || echo "localhost")
}

# Parse arguments
DOCKER_MODE=false
PROXY_PORT="${PROXY_PORT:-3000}"
API_PORT="${API_PORT:-3001}"

for arg in "$@"; do
    case "$arg" in
        --docker) DOCKER_MODE=true ;;
        --client-only) ENABLE_CLIENT=true; ENABLE_API=false; ENABLE_DB_SERVICE=false; ENABLE_QUEUE=false; ENABLE_WORKER=false ;;
        --help)
            cat <<EOF
Usage: $0 [OPTIONS]

Start all workspace services.

Options:
  --docker        Start services in Docker
  --client-only   Start only client and proxy
  --help          Show this help message
EOF
            exit 0
            ;;
    esac
done

# Set LOCAL_HOST and exports
set_local_host
export LOCAL_HOST HOST_ID="${HOST_ID:-local}" API_HOST="${API_HOST:-$LOCAL_HOST}" API_PORT PROXY_PORT QUEUE_HOST="${QUEUE_HOST:-$LOCAL_HOST}"

# Construct API URL for display
API_HOST_WITH_SCHEME="$API_HOST"
[[ ! "$API_HOST_WITH_SCHEME" =~ ^https?:// ]] && API_HOST_WITH_SCHEME="http://$API_HOST_WITH_SCHEME"
API_URL="$API_HOST_WITH_SCHEME:$API_PORT"

# Display configuration
log "Starting services:"
log "  WORKER:      $ENABLE_WORKER"
log "  CLIENT:      $ENABLE_CLIENT"
log "  API:         $ENABLE_API"
log "  DB_SERVICE:  $ENABLE_DB_SERVICE"
log "  QUEUE:       $ENABLE_QUEUE"
log "  DB:          $ENABLE_DB"
echo ""

# Client-only mode: build client and start proxy only
if [[ "$ENABLE_API" == "false" && "$ENABLE_CLIENT" == "true" ]]; then
    log "Client-only mode: building frontend and starting proxy"
    
    if [[ "$DOCKER_MODE" == "true" ]]; then
        "$CLIENT_DIR/build" && "$PROXY_DIR/build" --docker
    else
        npm --prefix "$CLIENT_DIR" run build
        rm -rf "$PROXY_DIR/public"
        mkdir -p "$PROXY_DIR/public"
        cp -R "$CLIENT_DIR/dist/." "$PROXY_DIR/public/"
    fi
    
    log "Starting proxy on port $PROXY_PORT"
    log "Configure API_HOST to point to remote API (current: $API_URL)"
    
    [[ "$DOCKER_MODE" == "true" ]] && PROXY_PORT="$PROXY_PORT" API_PORT="$API_PORT" API_HOST="$API_HOST" "$PROXY_DIR/start" --docker || API_URL="$API_URL" PORT="$PROXY_PORT" npm --prefix "$PROXY_DIR" start
    exit 0
fi

# Determine if sudo is needed
NEEDS_SUDO=false
[[ "$ENABLE_DB" == "true" && "$DOCKER_MODE" == "false" && "$ENABLE_API" == "true" ]] && NEEDS_SUDO=true
[[ "$ENABLE_DB" == "true" && "$DOCKER_MODE" == "false" && "$ENABLE_API" != "true" ]] && NEEDS_SUDO=true
[[ "$ENABLE_API" == "true" && "$DOCKER_MODE" == "false" ]] && NEEDS_SUDO=true
[[ "$ENABLE_WORKER" == "true" ]] && NEEDS_SUDO=true

$NEEDS_SUDO && ensure_sudo_once "Services require sudo access for PostgreSQL/libvirt/nftables operations."

# Validate API prerequisites
if [[ "$ENABLE_API" == "true" && "$DOCKER_MODE" == "false" && ! -x "$PROVISIONER_PYTHON_BIN" ]]; then
    error "Provisioner Python interpreter not found at $PROVISIONER_PYTHON_BIN"
    echo "Run ./setup first" >&2
    exit 1
fi

[[ -x "$PROVISIONER_PYTHON_BIN" ]] && export HLVMP_PYTHON_BIN="$PROVISIONER_PYTHON_BIN"

# Process management
PIDS=()
CONTAINERS_STARTED=()

cleanup() {
    log "Stopping services..."
    for container in "${CONTAINERS_STARTED[@]}"; do
        docker rm -f "$container" >/dev/null 2>&1 || true
    done
    for pid in "${PIDS[@]}"; do
        kill "$pid" 2>/dev/null || true
    done
    for pid in "${PIDS[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
}

fail_startup() {
    cleanup
    exit 1
}

trap cleanup EXIT INT TERM

ensure_process_started() {
    if ! kill -0 "$1" 2>/dev/null; then
        error "$2 exited during startup"
        wait "$1" || true
        fail_startup
    fi
}

ensure_client_assets() {
    [[ -f "$PROXY_PUBLIC_INDEX" ]] && return
    
    log "Building client assets"
    [[ "$DOCKER_MODE" == "true" ]] && "$CLIENT_DIR/build" --docker || "$CLIENT_DIR/build"
    rm -rf "$PROXY_DIR/public"
    mkdir -p "$PROXY_DIR/public"
    cp -R "$CLIENT_DIR/dist/." "$PROXY_DIR/public/"
}

ensure_image() {
    local image="$1"
    local build_script="$2"
    docker image inspect "$image" >/dev/null 2>&1 && return
    log "Building Docker image: $image"
    "$build_script" --docker
}

wait_for_service() {
    local name="$1"
    local url="$2"
    command -v curl >/dev/null 2>&1 || { sleep 5; return; }
    log "Waiting for $name at $url"
    for _ in {1..30}; do
        curl -fsS "$url" >/dev/null 2>&1 && return
        sleep 1
    done
    error "$name did not become ready at $url"
    fail_startup
}

wait_for_postgres_container() {
    local name="$1"
    command -v docker >/dev/null 2>&1 || { sleep 5; return; }
    log "Waiting for PostgreSQL in $name"
    for _ in {1..30}; do
        docker exec "$name" pg_isready -U "${POSTGRES_USER:-hlvmp}" >/dev/null 2>&1 && return
        sleep 1
    done
    error "PostgreSQL in $name did not become ready"
    fail_startup
}

start_container() {
    local name="$1"
    local start_script="$2"
    shift 2
    
    local id_before="$(docker inspect -f '{{.Id}}' "$name" 2>/dev/null || true)"
    local was_running="$(docker inspect -f '{{.State.Running}}' "$name" 2>/dev/null || echo 'false')"
    
    "$start_script" "$@"
    
    local id_after="$(docker inspect -f '{{.Id}}' "$name" 2>/dev/null || true)"
    if [[ -n "$id_after" && ( "$was_running" != "true" || "$id_before" != "$id_after" ) ]]; then
        CONTAINERS_STARTED+=("$name")
    fi
}

# Start services
[[ "$ENABLE_DB" == "true" && "$DOCKER_MODE" == "false" ]] && log "Starting native PostgreSQL" && "$DB_DIR/start"

if [[ "$ENABLE_QUEUE" == "true" ]]; then
    log "Starting RabbitMQ queue"
    [[ "$DOCKER_MODE" == "true" ]] && start_container hlvmp-rabbitmq "$QUEUE_DIR/start" --docker || "$QUEUE_DIR/start"
fi

[[ "$ENABLE_CLIENT" == "true" ]] && ensure_client_assets
[[ "$DOCKER_MODE" == "true" ]] && ensure_image homelab-vm-provisioner-proxy:latest "$PROXY_DIR/build" && ensure_image homelab-vm-provisioner-api:latest "$API_DIR/build"

# Start database (PostgreSQL) and db-interface microservice
if [[ "$DOCKER_MODE" == "true" ]]; then
    if [[ "$ENABLE_DB" == "true" ]]; then
        ensure_image hlvmp-db:latest "$DB_DIR/build"
        log "Starting PostgreSQL in Docker"
        start_container hlvmp-db "$DB_DIR/start" --docker --no-follow
        wait_for_postgres_container hlvmp-db
    fi
    if [[ "$ENABLE_DB_SERVICE" == "true" ]]; then
        ensure_image hlvmp-db-interface:latest "$DB_INTERFACE_DIR/build"
        log "Starting db-interface in Docker"
        DB_POSTGRES_HOST="${POSTGRES_HOST:-localhost}"
        [[ "$DB_POSTGRES_HOST" == "localhost" ]] && DB_POSTGRES_HOST="172.17.0.1"
        POSTGRES_HOST="$DB_POSTGRES_HOST" start_container hlvmp-db-interface "$DB_INTERFACE_DIR/start" --docker --no-follow
        wait_for_service "db-interface" "http://localhost:${DB_SERVICE_PORT:-3002}/health"
    fi
elif [[ "$ENABLE_DB_SERVICE" == "true" ]]; then
    log "Starting db-interface microservice on port ${DB_SERVICE_PORT:-3002}"
    "$DB_INTERFACE_DIR/start" &
    DB_PID=$!
    PIDS+=("$DB_PID")
    sleep 2
    ensure_process_started "$DB_PID" "db-interface microservice"
fi

# Start API
if [[ "$ENABLE_API" == "true" ]]; then
    log "Starting API on port $API_PORT"
    if [[ "$DOCKER_MODE" == "true" ]]; then
        # Docker mode: connect to other services via 172.17.0.1
        DB_SERVICE_HOST="${DB_SERVICE_HOST:-localhost}"
        [[ "$DB_SERVICE_HOST" == "localhost" ]] && DB_SERVICE_HOST="172.17.0.1"
        QUEUE_HOST_API="${QUEUE_HOST:-localhost}"
        [[ "$QUEUE_HOST_API" == "localhost" ]] && QUEUE_HOST_API="172.17.0.1"
        
        DB_SERVICE_HOST="$DB_SERVICE_HOST" QUEUE_HOST="$QUEUE_HOST_API" start_container hlvmp-api "$API_DIR/start" --docker --no-follow
        wait_for_service "API" "http://localhost:$API_PORT/health"
    else
        API_PORT="$API_PORT" "$API_DIR/start" &
        API_PID=$!
        PIDS+=("$API_PID")
        sleep 2
        ensure_process_started "$API_PID" "API"
    fi
fi

# Start proxy
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    if [[ "$DOCKER_MODE" == "true" ]]; then
        PROXY_PORT="$PROXY_PORT" API_PORT="$API_PORT" API_HOST="$API_HOST" "$PROXY_DIR/start" --docker &
        PROXY_PID=$!
        PIDS+=("$PROXY_PID")
    else
        log "Starting proxy on port $PROXY_PORT"
        log "Access the application at http://localhost:$PROXY_PORT"
        PORT="$PROXY_PORT" npm --prefix "$PROXY_DIR" start &
        PROXY_PID=$!
        PIDS+=("$PROXY_PID")
    fi
fi

# Start worker (always last)
if [[ "$ENABLE_WORKER" == "true" ]]; then
    log "Starting worker daemon"
    if [[ "$DOCKER_MODE" == "true" ]]; then
        # Worker runs natively, connects to Docker services via localhost
        (export QUEUE_HOST=localhost API_HOST=localhost DB_SERVICE_HOST=localhost; "$WORKER_DIR/start") 2>&1 | sed 's/^/[WORKER] /' &
    else
        "$WORKER_DIR/start" 2>&1 | sed 's/^/[WORKER] /' &
    fi
    WORKER_PID=$!
    PIDS+=("$WORKER_PID")
    sleep 1
    ensure_process_started "$WORKER_PID" "Worker daemon"
fi

# Wait for services
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    wait "${PROXY_PID:-$$}"
else
    log "Services started in background. Press Ctrl+C to stop."
    wait -n
fi
