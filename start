#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
CLIENT_DIR="$ROOT_DIR/homelab-vm-provisioner-client"
DB_DIR="$ROOT_DIR/homelab-vm-provisioner-db"
PROXY_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy"
WORKER_DIR="$ROOT_DIR/homelab-vm-provisioner-worker"
QUEUE_DIR="$ROOT_DIR/homelab-vm-provisioner-job-queue"
PROXY_PUBLIC_INDEX="$PROXY_DIR/public/index.html"

PROVISIONER_CLI_PATH="${PROVISIONER_CLI_PATH:-homelab-vm-provisioner-cli}"
if [[ "$PROVISIONER_CLI_PATH" != /* ]]; then
    PROVISIONER_DIR="$ROOT_DIR/$PROVISIONER_CLI_PATH"
else
    PROVISIONER_DIR="$PROVISIONER_CLI_PATH"
fi

relative_path() {
    python3 -c 'import os,sys; print(os.path.relpath(sys.argv[2], sys.argv[1]))' "$1" "$2"
}

normalize_provisioner_env() {
    export PROVISIONER_CLI_PATH="$PROVISIONER_DIR"

    if [[ -n "${PROVISIONER_DATA_DIR:-}" && "$PROVISIONER_DATA_DIR" != /* ]]; then
        local data_dir_absolute="$ROOT_DIR/$PROVISIONER_DATA_DIR"
        export PROVISIONER_DATA_DIR="$(relative_path "$PROVISIONER_DIR" "$data_dir_absolute")"
    fi
}

# Source .env file if it exists
if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    source "$ROOT_DIR/.env"
    set +a
fi

# Build mode defaults (can be overridden by .env)
ENABLE_CLIENT="${ENABLE_CLIENT:-true}"
ENABLE_API="${ENABLE_API:-true}"
ENABLE_DB_SERVICE="${ENABLE_DB_SERVICE:-true}"
ENABLE_DB="${ENABLE_DB:-true}"
ENABLE_WORKER="${ENABLE_WORKER:-true}"
ENABLE_QUEUE="${ENABLE_QUEUE:-true}"

PROVISIONER_VENV_DIR="${PROVISIONER_VENV_DIR:-$PROVISIONER_DIR/.venv}"
PROVISIONER_PYTHON_BIN="$PROVISIONER_VENV_DIR/bin/python"

normalize_provisioner_env

# Parse arguments for Docker mode and legacy client-only mode
USE_DOCKER=false
PROXY_PORT="${PROXY_PORT:-3000}"
API_PORT="${API_PORT:-3001}"

# Construct API_URL from PROXY_API_HOST and API_PORT
PROXY_API_HOST="${PROXY_API_HOST:-http://172.17.0.1}"
API_URL="$PROXY_API_HOST:$API_PORT"

log() {
    printf '==> %s\n' "$*"
}

docker_container_exists() {
    docker inspect "$1" >/dev/null 2>&1
}

docker_container_running() {
    [[ "$(docker inspect -f '{{.State.Running}}' "$1" 2>/dev/null || true)" == "true" ]]
}

docker_container_id() {
    docker inspect -f '{{.Id}}' "$1" 2>/dev/null || true
}

docker_container_image_id() {
    docker inspect -f '{{.Image}}' "$1" 2>/dev/null || true
}

docker_container_label() {
    local container_name="$1"
    local label_name="$2"
    docker inspect -f "{{index .Config.Labels \"$label_name\"}}" "$container_name" 2>/dev/null || true
}

docker_image_id() {
    docker image inspect -f '{{.Id}}' "$1" 2>/dev/null || true
}

ensure_sudo_credentials() {
    local reason="$1"

    if [[ "${EUID}" -eq 0 ]]; then
        return
    fi

    if ! command -v sudo >/dev/null 2>&1; then
        printf 'sudo is required for this start step but is not installed.\n' >&2
        exit 1
    fi

    if sudo -n -v >/dev/null 2>&1; then
        return
    fi

    if [[ ! -t 0 || ! -t 1 ]]; then
        printf '%s\n' "$reason" >&2
        printf 'Run this script from an interactive terminal or pre-authorize sudo with `sudo -v` first.\n' >&2
        exit 1
    fi

    log "$reason"
    sudo -v
}

for arg in "$@"; do
    case "$arg" in
        --docker)
            USE_DOCKER=true
            ;;
        --client-only)
            # Legacy flag support - sets mode flags
            ENABLE_CLIENT=true
            ENABLE_API=false
            ENABLE_DB_SERVICE=false
            ENABLE_QUEUE=false
            ENABLE_WORKER=false
            ;;
    esac
done

# Display enabled services
printf '==> Starting services with configuration:\n'
printf '    WORKER:      %s\n' "$ENABLE_WORKER"
printf '    CLIENT:      %s\n' "$ENABLE_CLIENT"
printf '    API:         %s\n' "$ENABLE_API"
printf '    DB_SERVICE:  %s\n' "$ENABLE_DB_SERVICE"
printf '    QUEUE:       %s\n' "$ENABLE_QUEUE"
printf '    DB:          %s\n' "$ENABLE_DB"
printf '\n'

# Client-only mode: build client and start proxy only (no API)
if [[ "$ENABLE_API" == "false" && "$ENABLE_CLIENT" == "true" ]]; then
    printf '==> Client-only mode: building frontend and starting proxy\n'
    
    # Build client
    if [[ "$USE_DOCKER" == "true" ]]; then
        printf '==> Building client with Docker\n'
        "$ROOT_DIR/homelab-vm-provisioner-client/build"
    else
        printf '==> Building client locally\n'
        npm --prefix "$ROOT_DIR/homelab-vm-provisioner-client" run build
        
        printf '==> Deploying client bundle to proxy public directory\n'
        rm -rf "$PROXY_DIR/public"
        mkdir -p "$PROXY_DIR/public"
        cp -R "$ROOT_DIR/homelab-vm-provisioner-client/dist/." "$PROXY_DIR/public/"
    fi
    
    # Start proxy only (no API)
    if [[ "$USE_DOCKER" == "true" ]]; then
        # Check if Docker image exists
        if ! docker image inspect homelab-vm-provisioner-proxy:latest >/dev/null 2>&1; then
            printf 'Docker image not found. Run ./setup --docker or ./homelab-vm-provisioner-proxy/build first.\n' >&2
            exit 1
        fi
        printf '==> Configure PROXY_API_HOST to point to remote API (current: %s)\n' "$API_URL"

        PROXY_PORT="$PROXY_PORT" API_PORT="$API_PORT" PROXY_API_HOST="$PROXY_API_HOST" "$PROXY_DIR/start" --docker
    else
        printf '==> Starting proxy locally on port %s\n' "$PROXY_PORT"
        printf '==> Configure PROXY_API_HOST to point to remote API (current: %s)\n' "$API_URL"
        printf '==> Access the application at http://localhost:%s\n' "$PROXY_PORT"
        
        API_URL="$API_URL" PORT="$PROXY_PORT" npm --prefix "$PROXY_DIR" start
    fi
    
    exit 0
fi

if [[ "$ENABLE_DB" == "true" && "$USE_DOCKER" == "false" && "$ENABLE_API" == "true" ]]; then
    ensure_sudo_credentials "Native PostgreSQL startup and API libvirt operations require sudo access. Confirm it now before services start in the background."
elif [[ "$ENABLE_DB" == "true" && "$USE_DOCKER" == "false" ]]; then
    ensure_sudo_credentials "Starting native PostgreSQL requires sudo access. Confirm it now before services start."
elif [[ "$ENABLE_API" == "true" && "$USE_DOCKER" == "false" ]]; then
    ensure_sudo_credentials "The API needs sudo access for libvirt operations and privileged log access. Confirm it now before the API starts in the background."
fi

# Validate prerequisites for full-stack mode
if [[ "$ENABLE_API" == "true" && "$USE_DOCKER" == "false" && ! -x "$PROVISIONER_PYTHON_BIN" ]]; then
    printf 'Provisioner Python interpreter not found at %s\n' "$PROVISIONER_PYTHON_BIN" >&2
    printf 'Run ./setup first so the provisioner is installed for the API bridge.\n' >&2
    exit 1
fi

if [[ -x "$PROVISIONER_PYTHON_BIN" ]]; then
    export HLVMP_PYTHON_BIN="$PROVISIONER_PYTHON_BIN"
fi

# Start services based on mode configuration
PIDS=()
DB_CONTAINER_STARTED=false
API_CONTAINER_STARTED=false
PROXY_CONTAINER_STARTED=false

cleanup_db_container() {
    if [[ "$DB_CONTAINER_STARTED" == "true" ]]; then
        docker stop hlvmp-db >/dev/null 2>&1 || true
        docker rm -f hlvmp-db >/dev/null 2>&1 || true
    fi
}

cleanup_proxy_container() {
    if [[ "$PROXY_CONTAINER_STARTED" == "true" ]]; then
        docker rm -f hlvmp-proxy >/dev/null 2>&1 || true
    fi
}

cleanup_api_container() {
    if [[ "$API_CONTAINER_STARTED" == "true" ]]; then
        docker rm -f hlvmp-api >/dev/null 2>&1 || true
    fi
}

fail_startup() {
    cleanup_proxy_container
    cleanup_api_container
    cleanup_db_container
    for pid in "${PIDS[@]}"; do
        kill "$pid" 2>/dev/null || true
    done
    for pid in "${PIDS[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
    exit 1
}

cleanup() {
    printf '\n==> Stopping services...\n'
    cleanup_proxy_container
    cleanup_api_container
    cleanup_db_container
    for pid in "${PIDS[@]}"; do
        kill "$pid" 2>/dev/null || true
    done
    for pid in "${PIDS[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
}

ensure_process_started() {
    local pid="$1"
    local name="$2"

    if ! kill -0 "$pid" 2>/dev/null; then
        printf '==> %s exited during startup\n' "$name" >&2
        wait "$pid" || true
        fail_startup
    fi
}

ensure_client_assets() {
    if [[ -f "$PROXY_PUBLIC_INDEX" ]]; then
        return
    fi

    printf '==> Client bundle not found; building and deploying client assets\n'
    if [[ "$USE_DOCKER" == "true" ]]; then
        "$CLIENT_DIR/build" --docker
    else
        "$CLIENT_DIR/build"
    fi

    rm -rf "$PROXY_DIR/public"
    mkdir -p "$PROXY_DIR/public"
    cp -R "$CLIENT_DIR/dist/." "$PROXY_DIR/public/"
}

ensure_proxy_image() {
    if [[ "$USE_DOCKER" != "true" ]]; then
        return
    fi

    if docker image inspect homelab-vm-provisioner-proxy:latest >/dev/null 2>&1; then
        return
    fi

    printf '==> Proxy Docker image not found; building it now\n'
    "$PROXY_DIR/build" --docker
}

ensure_db_image() {
    if [[ "$USE_DOCKER" != "true" ]]; then
        return
    fi

    if docker image inspect hlvmp-db:latest >/dev/null 2>&1; then
        return
    fi

    printf '==> Database Docker image not found; building it now\n'
    "$DB_DIR/build" --docker
}

ensure_api_image() {
    if [[ "$USE_DOCKER" != "true" ]]; then
        return
    fi

    if docker image inspect homelab-vm-provisioner-api:latest >/dev/null 2>&1; then
        return
    fi

    printf '==> API Docker image not found; building it now\n'
    "$API_DIR/build" --docker
}

wait_for_api_service() {
    if [[ "$ENABLE_API" != "true" ]]; then
        return
    fi

    local health_url="http://localhost:${API_PORT}/health"

    if ! command -v curl >/dev/null 2>&1; then
        sleep 5
        return
    fi

    printf '==> Waiting for API at %s\n' "$health_url"
    for _ in {1..30}; do
        if curl -fsS "$health_url" >/dev/null 2>&1; then
            return
        fi
        sleep 1
    done

    printf 'API did not become ready at %s\n' "$health_url" >&2
    fail_startup
}

wait_for_db_service() {
    if [[ "$ENABLE_DB_SERVICE" != "true" ]]; then
        return
    fi

    local db_service_port="${DB_SERVICE_PORT:-3002}"
    local health_url="http://localhost:${db_service_port}/health"

    if ! command -v curl >/dev/null 2>&1; then
        sleep 5
        return
    fi

    printf '==> Waiting for database microservice at %s\n' "$health_url"
    for _ in {1..30}; do
        if curl -fsS "$health_url" >/dev/null 2>&1; then
            return
        fi
        sleep 1
    done

    printf 'Database microservice did not become ready at %s\n' "$health_url" >&2
    fail_startup
}

# Start native PostgreSQL service when enabled
if [[ "$ENABLE_DB" == "true" && "$USE_DOCKER" == "false" ]]; then
    printf '==> Starting native PostgreSQL service\n'
    "$DB_DIR/start"
fi

# Start RabbitMQ queue service when enabled
if [[ "$ENABLE_QUEUE" == "true" ]]; then
    printf '==> Starting RabbitMQ queue service\n'
    if [[ "$USE_DOCKER" == "true" ]]; then
        "$QUEUE_DIR/start" --docker
    else
        "$QUEUE_DIR/start"
    fi
fi

if [[ "$ENABLE_CLIENT" == "true" ]]; then
    ensure_client_assets
    ensure_proxy_image
fi

if [[ "$ENABLE_API" == "true" ]]; then
    ensure_api_image
fi

# Start database stack
if [[ "$USE_DOCKER" == "true" && ( "$ENABLE_DB_SERVICE" == "true" || "$ENABLE_DB" == "true" ) ]]; then
    DB_SERVICE_PORT="${DB_SERVICE_PORT:-3002}"
    ensure_db_image
    DB_CONTAINER_ID_BEFORE="$(docker_container_id hlvmp-db)"
    DB_WAS_RUNNING_BEFORE="$(docker inspect -f '{{.State.Running}}' hlvmp-db 2>/dev/null || printf 'false')"
    printf '==> Starting database stack in Docker\n'
    "$DB_DIR/start" --docker
    DB_CONTAINER_ID_AFTER="$(docker_container_id hlvmp-db)"
    if [[ -n "$DB_CONTAINER_ID_AFTER" ]] && [[ "$DB_WAS_RUNNING_BEFORE" != "true" || "$DB_CONTAINER_ID_BEFORE" != "$DB_CONTAINER_ID_AFTER" ]]; then
        DB_CONTAINER_STARTED=true
    fi
    wait_for_db_service
elif [[ "$ENABLE_DB_SERVICE" == "true" ]]; then
    DB_SERVICE_PORT="${DB_SERVICE_PORT:-3002}"
    printf '==> Starting database microservice on port %s\n' "$DB_SERVICE_PORT"
    PORT="$DB_SERVICE_PORT" npm --prefix "$DB_DIR" start &
    DB_PID=$!
    PIDS+=("$DB_PID")
    sleep 2
    ensure_process_started "$DB_PID" "Database microservice"
fi

# Start API if enabled
if [[ "$ENABLE_API" == "true" ]]; then
    printf '==> Starting API on port %s\n' "$API_PORT"
    if [[ "$USE_DOCKER" == "true" ]]; then
        API_CONTAINER_ID_BEFORE="$(docker_container_id hlvmp-api)"
        API_WAS_RUNNING_BEFORE="$(docker inspect -f '{{.State.Running}}' hlvmp-api 2>/dev/null || printf 'false')"
        API_DB_SERVICE_URL="${DB_SERVICE_URL:-}"
        if [[ -z "$API_DB_SERVICE_URL" || "$API_DB_SERVICE_URL" == "http://localhost:${DB_SERVICE_PORT:-3002}" ]]; then
            API_DB_SERVICE_URL="http://172.17.0.1:${DB_SERVICE_PORT:-3002}"
        fi
        DB_SERVICE_URL="$API_DB_SERVICE_URL" "$API_DIR/start" --docker
        API_CONTAINER_ID_AFTER="$(docker_container_id hlvmp-api)"
        if [[ -n "$API_CONTAINER_ID_AFTER" ]] && [[ "$API_WAS_RUNNING_BEFORE" != "true" || "$API_CONTAINER_ID_BEFORE" != "$API_CONTAINER_ID_AFTER" ]]; then
            API_CONTAINER_STARTED=true
        fi
        wait_for_api_service
    else
        API_PORT="$API_PORT" "$API_DIR/start" &
        API_PID=$!
        PIDS+=("$API_PID")
        sleep 2
        ensure_process_started "$API_PID" "API"
    fi
fi

# Start proxy if client is enabled
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    if [[ "$USE_DOCKER" == "true" ]]; then
        PROXY_PORT="$PROXY_PORT" API_PORT="$API_PORT" PROXY_API_HOST="$PROXY_API_HOST" "$PROXY_DIR/start" --docker &
        PROXY_PID=$!
        PIDS+=("$PROXY_PID")

        # Start worker last - after all other services are up
        if [[ "$ENABLE_WORKER" == "true" ]]; then
            printf '==> Starting worker daemon\n'
            "$WORKER_DIR/start" 2>&1 | sed 's/^/[WORKER] /' &
            WORKER_PID=$!
            PIDS+=("$WORKER_PID")
            sleep 1
            ensure_process_started "$WORKER_PID" "Worker daemon"
        fi

        trap cleanup EXIT INT TERM

        # Wait for proxy to exit
        wait "$PROXY_PID"
    else
        # Start proxy locally with npm
        printf '==> Starting proxy on port %s\n' "$PROXY_PORT"
        printf '==> Access the application at http://localhost:%s\n' "$PROXY_PORT"
        PORT="$PROXY_PORT" npm --prefix "$PROXY_DIR" start &
        PROXY_PID=$!
        PIDS+=("$PROXY_PID")

        # Start worker last - after all other services are up
        if [[ "$ENABLE_WORKER" == "true" ]]; then
            printf '==> Starting worker daemon\n'
            "$WORKER_DIR/start" 2>&1 | sed 's/^/[WORKER] /' &
            WORKER_PID=$!
            PIDS+=("$WORKER_PID")
            sleep 1
            ensure_process_started "$WORKER_PID" "Worker daemon"
        fi

        trap cleanup EXIT INT TERM
        wait "$PROXY_PID"
    fi
else
    # No proxy, just wait for background services
    
    # Start worker last - after all other services are up
    if [[ "$ENABLE_WORKER" == "true" ]]; then
        printf '==> Starting worker daemon\n'
        "$WORKER_DIR/start" 2>&1 | sed 's/^/[WORKER] /' &
        WORKER_PID=$!
        PIDS+=("$WORKER_PID")
        sleep 1
        ensure_process_started "$WORKER_PID" "Worker daemon"
    fi
    
    printf '==> Services started in background\n'
    printf '==> Press Ctrl+C to stop\n'

    trap cleanup EXIT INT TERM

    # Wait for any process to exit
    wait -n
fi
