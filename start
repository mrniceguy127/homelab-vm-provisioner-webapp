#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
API_DIR="$ROOT_DIR/homelab-vm-provisioner-api"
DB_DIR="$ROOT_DIR/homelab-vm-provisioner-db"
PROXY_DIR="$ROOT_DIR/homelab-vm-provisioner-proxy"
WORKER_DIR="$ROOT_DIR/homelab-vm-provisioner-worker"
PROXY_PUBLIC_INDEX="$PROXY_DIR/public/index.html"

# Source .env file if it exists
if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    source "$ROOT_DIR/.env"
    set +a
fi

# Build mode defaults (can be overridden by .env)
ENABLE_CLIENT="${ENABLE_CLIENT:-true}"
ENABLE_API="${ENABLE_API:-true}"
ENABLE_DB_SERVICE="${ENABLE_DB_SERVICE:-true}"
ENABLE_DB="${ENABLE_DB:-true}"
ENABLE_WORKER="${ENABLE_WORKER:-true}"

PROVISIONER_VENV_DIR="${PROVISIONER_VENV_DIR:-$API_DIR/homelab-vm-provisioner-cli/.venv}"
PROVISIONER_PYTHON_BIN="$PROVISIONER_VENV_DIR/bin/python"

# Parse arguments for Docker mode and legacy client-only mode
USE_DOCKER=false
PROXY_PORT="${PROXY_PORT:-3000}"
API_PORT="${API_PORT:-3001}"

# Construct API_URL from PROXY_API_HOST and API_PORT
PROXY_API_HOST="${PROXY_API_HOST:-http://172.17.0.1}"
API_URL="$PROXY_API_HOST:$API_PORT"

for arg in "$@"; do
    case "$arg" in
        --docker)
            USE_DOCKER=true
            ;;
        --client-only)
            # Legacy flag support - sets mode flags
            ENABLE_CLIENT=true
            ENABLE_API=false
            ENABLE_DB_SERVICE=false
            ENABLE_WORKER=false
            ;;
    esac
done

# Display enabled services
printf '==> Starting services with configuration:\n'
printf '    WORKER:      %s\n' "$ENABLE_WORKER"
printf '    CLIENT:      %s\n' "$ENABLE_CLIENT"
printf '    API:         %s\n' "$ENABLE_API"
printf '    DB_SERVICE:  %s\n' "$ENABLE_DB_SERVICE"
printf '    DB:          %s\n' "$ENABLE_DB"
printf '\n'

# Client-only mode: build client and start proxy only (no API)
if [[ "$ENABLE_API" == "false" && "$ENABLE_CLIENT" == "true" ]]; then
    printf '==> Client-only mode: building frontend and starting proxy\n'
    
    # Build client
    if [[ "$USE_DOCKER" == "true" ]]; then
        printf '==> Building client with Docker\n'
        "$ROOT_DIR/homelab-vm-provisioner-client/build"
    else
        printf '==> Building client locally\n'
        npm --prefix "$ROOT_DIR/homelab-vm-provisioner-client" run build
        
        printf '==> Deploying client bundle to proxy public directory\n'
        rm -rf "$PROXY_DIR/public"
        mkdir -p "$PROXY_DIR/public"
        cp -R "$ROOT_DIR/homelab-vm-provisioner-client/dist/." "$PROXY_DIR/public/"
    fi
    
    # Start proxy only (no API)
    if [[ "$USE_DOCKER" == "true" ]]; then
        # Check if Docker image exists
        if ! docker image inspect homelab-vm-provisioner-proxy:latest >/dev/null 2>&1; then
            printf 'Docker image not found. Run ./setup --docker or ./homelab-vm-provisioner-proxy/build first.\n' >&2
            exit 1
        fi
        
        printf '==> Starting proxy in Docker on port %s\n' "$PROXY_PORT"
        printf '==> Configure PROXY_API_HOST to point to remote API (current: %s)\n' "$API_URL"
        printf '==> Access the application at http://localhost:%s\n' "$PROXY_PORT"
        
        docker run --rm \
            --name hlvmp-proxy \
            -p "$PROXY_PORT:3000" \
            -e "API_URL=$API_URL" \
            -v "$PROXY_DIR/public:/app/public:ro" \
            homelab-vm-provisioner-proxy:latest
    else
        printf '==> Starting proxy locally on port %s\n' "$PROXY_PORT"
        printf '==> Configure PROXY_API_HOST to point to remote API (current: %s)\n' "$API_URL"
        printf '==> Access the application at http://localhost:%s\n' "$PROXY_PORT"
        
        API_URL="$API_URL" PORT="$PROXY_PORT" npm --prefix "$PROXY_DIR" start
    fi
    
    exit 0
fi

# Validate prerequisites for full-stack mode
if [[ "$ENABLE_CLIENT" == "true" && ! -f "$PROXY_PUBLIC_INDEX" ]]; then
    printf 'Client bundle not found at %s\n' "$PROXY_PUBLIC_INDEX" >&2
    printf 'Run ./setup first to build and deploy the client assets.\n' >&2
    exit 1
fi

if [[ "$ENABLE_API" == "true" && ! -x "$PROVISIONER_PYTHON_BIN" ]]; then
    printf 'Provisioner Python interpreter not found at %s\n' "$PROVISIONER_PYTHON_BIN" >&2
    printf 'Run ./setup first so the nested provisioner is installed for the API bridge.\n' >&2
    exit 1
fi

export HLVMP_PYTHON_BIN="$PROVISIONER_PYTHON_BIN"

# Start services based on mode configuration
PIDS=()

# Start database microservice if enabled
if [[ "$ENABLE_DB_SERVICE" == "true" || "$ENABLE_DB" == "true" ]]; then
    DB_SERVICE_PORT="${DB_SERVICE_PORT:-3002}"
    printf '==> Starting database microservice on port %s\n' "$DB_SERVICE_PORT"
    PORT="$DB_SERVICE_PORT" npm --prefix "$DB_DIR" start &
    DB_PID=$!
    PIDS+=("$DB_PID")
    sleep 2
fi

# Start API if enabled
if [[ "$ENABLE_API" == "true" ]]; then
    printf '==> Starting API on port %s\n' "$API_PORT"
    PORT="$API_PORT" npm --prefix "$API_DIR" start &
    API_PID=$!
    PIDS+=("$API_PID")
    sleep 2
fi

# Start worker if enabled
if [[ "$ENABLE_WORKER" == "true" ]]; then
    # Configure path conversion for monorepo mode if PROVISIONER_CLI_PATH is set
    if [[ -n "${PROVISIONER_CLI_PATH:-}" ]]; then
        # Convert relative path to absolute from ROOT_DIR, leave absolute paths unchanged
        if [[ "$PROVISIONER_CLI_PATH" != /* ]]; then
            export PROVISIONER_CLI_PATH="$ROOT_DIR/$PROVISIONER_CLI_PATH"
        else
            export PROVISIONER_CLI_PATH
        fi
    fi
    
    printf '==> Starting worker daemon\n'
    "$WORKER_DIR/start" &
    WORKER_PID=$!
    PIDS+=("$WORKER_PID")
    sleep 1
fi

# Start proxy if client is enabled
if [[ "$ENABLE_CLIENT" == "true" ]]; then
    if [[ "$USE_DOCKER" == "true" ]]; then
        # Check if Docker image exists
        if ! docker image inspect homelab-vm-provisioner-proxy:latest >/dev/null 2>&1; then
            printf 'Docker image not found. Run ./setup --docker or ./homelab-vm-provisioner-proxy/build first.\n' >&2
            for pid in "${PIDS[@]}"; do
                kill "$pid" 2>/dev/null || true
            done
            exit 1
        fi
        
        # Start proxy in Docker container
        printf '==> Starting proxy in Docker on port %s\n' "$PROXY_PORT"
        printf '==> Proxying to API at %s\n' "$API_URL"
        printf '==> Access the application at http://localhost:%s\n' "$PROXY_PORT"
        
        docker run --rm \
            --name hlvmp-proxy \
            -p "$PROXY_PORT:3000" \
            -e "API_URL=$API_URL" \
            -v "$PROXY_DIR/public:/app/public:ro" \
            homelab-vm-provisioner-proxy:latest &
        PROXY_PID=$!
        PIDS+=("$PROXY_PID")
        
        # Trap to clean up all processes
        cleanup() {
            printf '\n==> Stopping services...\n'
            docker stop hlvmp-proxy 2>/dev/null || true
            for pid in "${PIDS[@]}"; do
                kill "$pid" 2>/dev/null || true
            done
            for pid in "${PIDS[@]}"; do
                wait "$pid" 2>/dev/null || true
            done
        }
        trap cleanup EXIT INT TERM
        
        # Wait for proxy to exit
        wait "$PROXY_PID"
    else
        # Start proxy locally with npm
        printf '==> Starting proxy on port %s\n' "$PROXY_PORT"
        printf '==> Access the application at http://localhost:%s\n' "$PROXY_PORT"
        PORT="$PROXY_PORT" npm --prefix "$PROXY_DIR" start
        
        # Clean up background processes on exit
        trap "for pid in ${PIDS[@]}; do kill \$pid 2>/dev/null || true; done" EXIT
    fi
else
    # No proxy, just wait for background services
    printf '==> Services started in background\n'
    printf '==> Press Ctrl+C to stop\n'
    
    cleanup() {
        printf '\n==> Stopping services...\n'
        for pid in "${PIDS[@]}"; do
            kill "$pid" 2>/dev/null || true
        done
        for pid in "${PIDS[@]}"; do
            wait "$pid" 2>/dev/null || true
        done
    }
    trap cleanup EXIT INT TERM
    
    # Wait for any process to exit
    wait -n
fi
