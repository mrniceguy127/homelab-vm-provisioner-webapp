# Environment configuration for homelab-vm-provisioner-db-interface
# Copy this file to .env and customize as needed
# Parent workspace .env variables are loaded first, then these override them

# ==============================================================================
# Network Configuration
# ==============================================================================

# LOCAL_HOST: Default host/IP for service binding (inherited from parent)
# By default, scripts dynamically set this based on mode (localhost for native, 172.17.0.1 for Docker)
#LOCAL_HOST=localhost

# ==============================================================================
# Microservice Configuration
# ==============================================================================

# Microservice port (defaults to 3002)
DB_SERVICE_PORT=3002

# Microservice authentication (shared secret)
# Change this to a strong password in production.
# API and worker must provide this in the Authorization header.
DB_SERVICE_PASSWORD=changeme_db_secret

# ==============================================================================
# PostgreSQL Connection
# ==============================================================================

# Connection settings for the PostgreSQL instance managed by
# homelab-vm-provisioner-db. POSTGRES_HOST defaults to LOCAL_HOST if not set.
#POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hlvmp
POSTGRES_PASSWORD=hlvmppass
POSTGRES_DB=hlvmp

# Legacy single-URL fallback (overrides the modular POSTGRES_* values when set)
#DATABASE_URL=postgresql://hlvmp:hlvmppass@localhost:5432/hlvmp
