#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source component .env
if [[ -f "$SCRIPT_DIR/.env" ]]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Parse arguments
DOCKER_MODE=false

for arg in "$@"; do
    case "$arg" in
        --docker)
            DOCKER_MODE=true
            ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Build the db-interface microservice."
            echo ""
            echo "Options:"
            echo "  --docker    Build the db-interface Docker image (node only)"
            echo "  --help      Show this help message"
            echo ""
            echo "Default: Verify Node.js and install production dependencies"
            exit 0
            ;;
    esac
done

log() {
    printf '==> %s\n' "$*"
}

cd "$SCRIPT_DIR"

if [[ "$DOCKER_MODE" == true ]]; then
    if ! command -v docker >/dev/null 2>&1; then
        log "Error: Docker not found. Install Docker Engine."
        exit 1
    fi

    log "Building hlvmp-db-interface Docker image (node microservice)"
    DB_SERVICE_PORT="${DB_SERVICE_PORT:-3002}"
    log "  Microservice Port: $DB_SERVICE_PORT"
    docker build \
        --build-arg DB_SERVICE_PORT="$DB_SERVICE_PORT" \
        -t hlvmp-db-interface:latest "$SCRIPT_DIR"

    log ""
    log "Build complete - Docker image ready: hlvmp-db-interface:latest"
    log "Start the container:"
    log "  ./start --docker"
else
    if ! command -v node >/dev/null 2>&1; then
        log "Error: Node.js not found. Run ./setup to install it."
        exit 1
    fi

    log "Verifying Node.js installation: $(node --version)"

    if [[ -f package-lock.json ]]; then
        log "Installing production dependencies (npm ci)"
        npm ci --omit=dev
    else
        log "Installing production dependencies (npm install)"
        npm install --omit=dev
    fi

    log ""
    log "Build complete - db-interface ready"
fi
